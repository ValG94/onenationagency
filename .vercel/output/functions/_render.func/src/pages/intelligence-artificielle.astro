---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Intelligence Artificielle & Agents IA — One Nation Agency"
  description="One Nation Agency crée des agents IA sur mesure pour qualifier vos prospects, automatiser vos processus et servir vos audiences 24h/24. Innovation au service de votre croissance."
>
  <Header />

  <main id="main-content">

    <!-- HERO IA -->
    <section class="ai-hero">
      <div class="ai-hero-bg" aria-hidden="true">
        <div class="ai-grid"></div>
        <div class="ai-glow"></div>
      </div>
      <div class="container">
        <div class="ai-hero-content">
          <span class="label reveal">Intelligence Artificielle</span>
          <div class="gold-bar reveal"></div>
          <h1 class="reveal reveal-delay-1">
            L'IA AU SERVICE<br />
            <span class="gold-text">DE VOTRE AMBITION.</span>
          </h1>
          <p class="ai-lead reveal reveal-delay-2">
            Nous concevons des agents IA sur mesure qui qualifient vos prospects, automatisent vos processus métier et servent vos audiences 24h/24, 7j/7 — en français, en anglais, et dans la langue de vos clients.
          </p>
          <div class="ai-hero-actions reveal reveal-delay-3">
            <a href="/contact" class="btn-gold">
              Discuter de votre projet IA
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#use-cases" class="btn-outline">Voir les cas d'usage</a>
          </div>
        </div>
      </div>
    </section>

    <!-- POURQUOI L'IA -->
    <section class="why-ai">
      <div class="container">
        <div class="why-ai-grid">
          <div class="why-ai-text">
            <span class="label reveal">Pourquoi l'IA ?</span>
            <div class="gold-bar reveal"></div>
            <h2 class="reveal">LE FUTUR EST DÉJÀ LÀ.</h2>
            <p class="reveal reveal-delay-1">
              Les organisations qui intègrent l'IA aujourd'hui prennent une longueur d'avance décisive sur leurs concurrents. Un agent IA bien conçu peut traiter des milliers d'interactions simultanément, qualifier des leads en temps réel et personnaliser chaque échange.
            </p>
            <p class="reveal reveal-delay-2">
              Chez One Nation Agency, nous ne nous contentons pas de déployer des chatbots génériques. Nous créons des <strong>intelligences conversationnelles sur mesure</strong>, formées sur votre domaine d'expertise, alignées sur votre identité de marque et intégrées à vos outils existants.
            </p>
            <div class="why-ai-stats reveal reveal-delay-3">
              <div class="ai-stat">
                <span class="ai-stat-num">24/7</span>
                <span class="ai-stat-label">Disponibilité</span>
              </div>
              <div class="ai-stat">
                <span class="ai-stat-num">-70%</span>
                <span class="ai-stat-label">Coût de traitement</span>
              </div>
              <div class="ai-stat">
                <span class="ai-stat-num">+3x</span>
                <span class="ai-stat-label">Taux de conversion</span>
              </div>
            </div>
          </div>
          <div class="why-ai-visual reveal">
            <div class="ai-demo-card">
              <div class="ai-demo-header">
                <div class="ai-demo-dot"></div>
                <span>Agent IA One Nation</span>
              </div>
              <div class="ai-demo-messages">
                <div class="ai-msg ai-msg--bot">
                  <p>Bonjour ! Je suis l'assistant de One Nation Agency. Comment puis-je vous aider aujourd'hui ?</p>
                </div>
                <div class="ai-msg ai-msg--user">
                  <p>Je cherche une agence pour ma campagne présidentielle.</p>
                </div>
                <div class="ai-msg ai-msg--bot">
                  <p>Excellente démarche. Nous avons accompagné plusieurs candidats en Afrique francophone. Quel est votre pays et votre calendrier électoral ?</p>
                </div>
                <div class="ai-typing">
                  <span></span><span></span><span></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- NOS AGENTS IA -->
    <section class="ai-products" id="use-cases">
      <div class="container">
        <div class="section-header reveal">
          <span class="label">Nos solutions</span>
          <div class="gold-bar"></div>
          <h2>NOS AGENTS IA</h2>
          <p class="section-intro">Chaque agent est conçu sur mesure pour répondre à vos objectifs spécifiques.</p>
        </div>

        <div class="ai-products-grid">
          <article class="ai-product-card reveal reveal-delay-1">
            <div class="ai-product-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <h3>Agent Commercial</h3>
            <p>Qualifie vos prospects entrants, répond aux questions fréquentes, prend des rendez-vous et transfère les leads chauds à votre équipe commerciale.</p>
            <ul class="ai-product-features">
              <li>Qualification automatique des leads</li>
              <li>Prise de rendez-vous intégrée</li>
              <li>CRM synchronisé</li>
              <li>Multilingue</li>
            </ul>
          </article>

          <article class="ai-product-card ai-product-card--featured reveal reveal-delay-2">
            <div class="ai-product-badge">Bestseller</div>
            <div class="ai-product-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="3"/>
                <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
              </svg>
            </div>
            <h3>Agent Institutionnel</h3>
            <p>Conçu pour les institutions, les partis politiques et les organisations publiques. Gère les demandes citoyennes, diffuse les messages officiels et oriente vers les bons interlocuteurs.</p>
            <ul class="ai-product-features">
              <li>Gestion des demandes citoyennes</li>
              <li>Diffusion de messages officiels</li>
              <li>Modération intelligente</li>
              <li>Reporting en temps réel</li>
            </ul>
          </article>

          <article class="ai-product-card reveal reveal-delay-3">
            <div class="ai-product-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <path d="M8 21h8M12 17v4"/>
              </svg>
            </div>
            <h3>Agent Événementiel</h3>
            <p>Gère les inscriptions, répond aux questions des participants, envoie des rappels et collecte les feedbacks pour vos conférences, sommets et événements.</p>
            <ul class="ai-product-features">
              <li>Gestion des inscriptions</li>
              <li>FAQ automatisée</li>
              <li>Rappels personnalisés</li>
              <li>Collecte de feedbacks</li>
            </ul>
          </article>
        </div>
      </div>
    </section>

    <!-- PROCESSUS -->
    <section class="ai-process">
      <div class="container">
        <div class="section-header reveal">
          <span class="label">Notre méthode</span>
          <div class="gold-bar"></div>
          <h2>COMMENT ÇA MARCHE ?</h2>
        </div>

        <div class="process-steps">
          <div class="process-step reveal reveal-delay-1">
            <div class="step-num">01</div>
            <h3>Audit & Cadrage</h3>
            <p>Nous analysons vos besoins, vos processus existants et vos objectifs pour définir le périmètre exact de votre agent IA.</p>
          </div>
          <div class="process-arrow" aria-hidden="true">→</div>
          <div class="process-step reveal reveal-delay-2">
            <div class="step-num">02</div>
            <h3>Conception & Formation</h3>
            <p>Nous formons l'agent sur votre domaine d'expertise, votre identité de marque et vos cas d'usage spécifiques.</p>
          </div>
          <div class="process-arrow" aria-hidden="true">→</div>
          <div class="process-step reveal reveal-delay-3">
            <div class="step-num">03</div>
            <h3>Intégration & Tests</h3>
            <p>Déploiement sur vos canaux (site web, WhatsApp, Messenger) avec une phase de tests intensifs et d'ajustements.</p>
          </div>
          <div class="process-arrow" aria-hidden="true">→</div>
          <div class="process-step reveal reveal-delay-4">
            <div class="step-num">04</div>
            <h3>Suivi & Optimisation</h3>
            <p>Monitoring continu, rapports mensuels et optimisations régulières pour maximiser les performances de votre agent.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA IA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-inner reveal">
          <span class="label">Passez à l'action</span>
          <h2>PRÊT À INTÉGRER<br /><span class="gold-text">L'IA DANS VOTRE ORGANISATION ?</span></h2>
          <p>Discutons de vos besoins et construisons ensemble l'agent IA qui fera la différence pour votre organisation.</p>
          <div class="cta-actions">
            <a href="/contact" class="btn-gold">
              Demander une démo
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="https://wa.me/33625523859" target="_blank" rel="noopener noreferrer" class="btn-outline">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-3.825 3.113-6.937 6.937-6.937 1.856.001 3.598.723 4.907 2.034 1.31 1.311 2.031 3.054 2.03 4.908-.001 3.825-3.113 6.938-6.937 6.938z"/></svg>
              WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* HERO IA */
  .ai-hero {
    position: relative;
    padding: 12rem 0 7rem;
    overflow: hidden;
  }
  .ai-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .ai-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(201,168,76,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,168,76,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .ai-glow {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
    border-radius: 50%;
  }
  .ai-hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .ai-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin: 1rem 0 1.5rem;
  }
  .ai-lead {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.85;
    max-width: 680px;
    margin: 0 auto 2.5rem;
  }
  .ai-hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* POURQUOI L'IA */
  .why-ai {
    padding: var(--pad-section);
    background: var(--anthracite);
    border-top: 1px solid var(--border);
  }
  .why-ai-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .why-ai-text h2 {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    margin-bottom: 1.5rem;
  }
  .why-ai-text p {
    margin-bottom: 1.2rem;
    font-size: 0.98rem;
    line-height: 1.85;
  }
  .why-ai-text strong { color: var(--white); font-weight: 600; }
  .why-ai-stats {
    display: flex;
    gap: 2rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-light);
  }
  .ai-stat { text-align: center; }
  .ai-stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .ai-stat-label {
    font-size: 0.72rem;
    color: var(--grey);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-display);
  }

  /* DEMO CARD */
  .why-ai-visual { display: flex; justify-content: center; }
  .ai-demo-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    max-width: 420px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
  .ai-demo-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1rem 1.2rem;
    background: rgba(201,168,76,0.06);
    border-bottom: 1px solid var(--border);
  }
  .ai-demo-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--gold);
    animation: pulseGold 2s ease-in-out infinite;
  }
  .ai-demo-header span {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--gold);
  }
  .ai-demo-messages {
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    min-height: 200px;
  }
  .ai-msg { max-width: 85%; }
  .ai-msg p {
    font-size: 0.85rem;
    line-height: 1.6;
    padding: 0.8rem 1rem;
    border-radius: 8px;
  }
  .ai-msg--bot p {
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.15);
    color: var(--off-white);
    border-radius: 0 8px 8px 8px;
  }
  .ai-msg--user {
    align-self: flex-end;
  }
  .ai-msg--user p {
    background: rgba(255,255,255,0.06);
    color: var(--grey-light);
    border-radius: 8px 0 8px 8px;
  }
  .ai-typing {
    display: flex;
    gap: 4px;
    padding: 0.8rem 1rem;
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.15);
    border-radius: 0 8px 8px 8px;
    width: fit-content;
  }
  .ai-typing span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gold);
    animation: typing 1.2s ease-in-out infinite;
  }
  .ai-typing span:nth-child(2) { animation-delay: 0.2s; }
  .ai-typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes typing {
    0%, 60%, 100% { opacity: 0.2; transform: translateY(0); }
    30% { opacity: 1; transform: translateY(-4px); }
  }

  /* PRODUITS IA */
  .ai-products {
    padding: var(--pad-section);
  }
  .ai-products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .ai-product-card {
    background: var(--card-bg);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 2.5rem 2rem;
    position: relative;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }
  .ai-product-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--border);
    transition: background 0.3s ease;
  }
  .ai-product-card:hover {
    border-color: var(--border);
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.4);
  }
  .ai-product-card:hover::before { background: var(--gold); }
  .ai-product-card--featured::before { background: var(--gold); }
  .ai-product-badge {
    position: absolute;
    top: 1.2rem; right: 1.2rem;
    background: var(--gold);
    color: var(--black);
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.25rem 0.6rem;
    border-radius: 2px;
  }
  .ai-product-icon {
    color: var(--gold);
    margin-bottom: 1.5rem;
  }
  .ai-product-card h3 {
    font-size: 1.2rem;
    font-weight: 800;
    margin-bottom: 0.8rem;
  }
  .ai-product-card > p {
    font-size: 0.88rem;
    color: var(--grey);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .ai-product-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .ai-product-features li {
    font-size: 0.82rem;
    color: var(--grey-light);
    padding-left: 1.2rem;
    position: relative;
  }
  .ai-product-features li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--gold);
    font-size: 0.75rem;
  }

  /* PROCESSUS */
  .ai-process {
    padding: var(--pad-section);
    background: var(--anthracite);
  }
  .process-steps {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-top: 3rem;
  }
  .process-step {
    flex: 1;
    background: var(--card-bg);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .process-step:hover {
    border-color: var(--gold);
    transform: translateY(-4px);
  }
  .step-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 900;
    color: rgba(201,168,76,0.2);
    line-height: 1;
    margin-bottom: 1rem;
  }
  .process-step h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.8rem;
  }
  .process-step p {
    font-size: 0.85rem;
    color: var(--grey);
    line-height: 1.7;
  }
  .process-arrow {
    font-size: 1.5rem;
    color: var(--gold);
    opacity: 0.4;
    flex-shrink: 0;
    margin-top: 3rem;
  }

  /* CTA */
  .cta-section {
    padding: var(--pad-section);
    border-top: 1px solid var(--border);
  }
  .cta-inner {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .cta-inner h2 {
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    margin: 0.8rem 0 1.5rem;
  }
  .cta-inner p {
    font-size: 1rem;
    color: var(--grey);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }
  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .why-ai-grid { grid-template-columns: 1fr; gap: 3rem; }
    .ai-products-grid { grid-template-columns: 1fr 1fr; }
    .process-steps { flex-direction: column; }
    .process-arrow { display: none; }
  }

  @media (max-width: 768px) {
    .ai-hero { padding: 9rem 0 5rem; }
    .ai-products-grid { grid-template-columns: 1fr; }
    .why-ai-stats { gap: 1.5rem; }
    .ai-hero-actions { flex-direction: column; align-items: center; }
  }
</style>

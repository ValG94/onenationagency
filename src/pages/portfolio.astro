---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const projects = [
  {
    id: 1,
    title: "AFAC26 — Site trilingue, agent IA et solution de paiement pour une conférence d'envergure internationale",
    category: "Intelligence Artificielle",
    client: "AFAC26",
    description: "Conférence internationale des agents de football africains",
    image: "/Afac26_home.jpg",
    url: "https://afac26.com",
    tags: ["IA", "Trilingue", "E-commerce", "Événementiel"]
  },
  {
    id: 2,
    title: "Campagne présidentielle 2026 — Alexis Mohamed (Djibouti)",
    category: "Communication 360",
    client: "Alexis Mohamed",
    description: "Stratégie digitale et communication institutionnelle",
    image: "/homeMohamed.jpg",
    url: null,
    tags: ["Politique", "Stratégie", "Influence", "Afrique"]
  },
  {
    id: 3,
    title: "Campagne présidentielle 2025 — Serge Ghislain Djorie (Centrafrique)",
    category: "Communication 360",
    client: "Dr Serge Ghislain Djorie",
    description: "Communication institutionnelle et stratégie d'influence",
    image: "/homeGhislain.jpg",
    url: null,
    tags: ["Politique", "Stratégie", "Afrique Centrale"]
  },
  {
    id: 4,
    title: "Nomadéo Africa website",
    category: "Digital",
    client: "Nomadéo",
    description: "Magasin de mobilier de bureau au Cameroun et en Afrique",
    image: "/nomadeo africa home.jpg",
    url: null,
    tags: ["E-commerce", "B2B", "Afrique"]
  },
  {
    id: 5,
    title: "Coplacam refonte site Internet",
    category: "Digital",
    client: "Coplacam Design & Build",
    description: "Refonte du site web de l'entreprise de construction",
    image: "/coplacam.jpg",
    url: null,
    tags: ["Corporate", "BTP", "Cameroun"]
  },
  {
    id: 6,
    title: "Centrachat Africa — 1ère centrale d'achats panafricaine",
    category: "Digital",
    client: "Centrachat International",
    description: "Plateforme B2B premium, Yaoundé, Cameroun — 500+ membres, 6 pays CEMAC, 30% d'économies",
    image: "/centrachat_home.webp",
    url: "https://www.centrachat.africa",
    tags: ["B2B", "Plateforme", "Afrique", "Innovation"]
  }
];
---

<Layout
  title="Portfolio — One Nation Agency"
  description="Découvrez nos réalisations : campagnes institutionnelles, agents IA, plateformes web premium. One Nation Agency — Excellence stratégique et innovation digitale."
>
  <Header />

  <main id="main-content">

    <!-- HERO PORTFOLIO -->
    <section class="portfolio-hero">
      <div class="container">
        <div class="portfolio-hero-content">
          <span class="label reveal">Portfolio</span>
          <div class="gold-bar reveal"></div>
          <h1 class="reveal reveal-delay-1">
            NOS RÉALISATIONS.<br />
            <span class="gold-text">VOTRE INSPIRATION.</span>
          </h1>
          <p class="portfolio-lead reveal reveal-delay-2">
            De la communication institutionnelle aux agents IA, en passant par les plateformes digitales premium, découvrez comment nous transformons les ambitions en réalisations concrètes.
          </p>
        </div>
      </div>
    </section>

    <!-- FILTRES -->
    <section class="portfolio-filters">
      <div class="container">
        <div class="filters-wrap reveal">
          <button class="filter-btn active" data-filter="all">Tous les projets</button>
          <button class="filter-btn" data-filter="Intelligence Artificielle">Intelligence Artificielle</button>
          <button class="filter-btn" data-filter="Communication 360">Communication 360</button>
          <button class="filter-btn" data-filter="Digital">Digital</button>
        </div>
      </div>
    </section>

    <!-- GRILLE PORTFOLIO -->
    <section class="portfolio-grid-section">
      <div class="container">
        <div class="portfolio-grid">
          {projects.map((project, idx) => (
            <article
              class={`portfolio-card reveal reveal-delay-${(idx % 3) + 1}`}
              data-category={project.category}
            >
              {project.url ? (
                <a href={project.url} target="_blank" rel="noopener noreferrer" class="portfolio-card-link">
                  <div class="portfolio-img-wrap">
                    <img src={project.image} alt={project.title} loading="lazy" />
                    <div class="portfolio-overlay">
                      <span class="portfolio-visit">Voir le projet</span>
                    </div>
                  </div>
                  <div class="portfolio-info">
                    <span class="portfolio-cat">{project.category}</span>
                    <h3>{project.title}</h3>
                    <p class="portfolio-client">Client : {project.client}</p>
                    <p class="portfolio-desc">{project.description}</p>
                    <div class="portfolio-tags">
                      {project.tags.map(tag => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </a>
              ) : (
                <div class="portfolio-card-link">
                  <div class="portfolio-img-wrap">
                    <img src={project.image} alt={project.title} loading="lazy" />
                    <div class="portfolio-overlay">
                      <span class="portfolio-visit">Voir le projet</span>
                    </div>
                  </div>
                  <div class="portfolio-info">
                    <span class="portfolio-cat">{project.category}</span>
                    <h3>{project.title}</h3>
                    <p class="portfolio-client">Client : {project.client}</p>
                    <p class="portfolio-desc">{project.description}</p>
                    <div class="portfolio-tags">
                      {project.tags.map(tag => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-inner reveal">
          <span class="label">Un projet en tête ?</span>
          <h2>CRÉONS QUELQUE CHOSE<br /><span class="gold-text">D'EXCEPTIONNEL.</span></h2>
          <p>Que vous ayez besoin d'une stratégie de communication, d'un agent IA ou d'une plateforme digitale premium, notre équipe est prête à vous accompagner.</p>
          <div class="cta-actions">
            <a href="/contact" class="btn-gold">
              Discutons de votre projet
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* HERO PORTFOLIO */
  .portfolio-hero {
    padding: 12rem 0 5rem;
    background: linear-gradient(135deg, var(--black) 0%, var(--anthracite) 100%);
    border-bottom: 1px solid var(--border);
  }
  .portfolio-hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .portfolio-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin: 1rem 0 1.5rem;
  }
  .portfolio-lead {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.85;
    max-width: 680px;
    margin: 0 auto;
  }

  /* FILTRES */
  .portfolio-filters {
    padding: 3rem 0;
    background: var(--anthracite);
    border-bottom: 1px solid var(--border-light);
  }
  .filters-wrap {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .filter-btn {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.65rem 1.4rem;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--grey);
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.25s ease;
  }
  .filter-btn:hover {
    color: var(--white);
    border-color: var(--gold);
  }
  .filter-btn.active {
    background: var(--gold);
    color: var(--black);
    border-color: var(--gold);
  }

  /* GRILLE PORTFOLIO */
  .portfolio-grid-section {
    padding: var(--pad-section);
  }
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .portfolio-card {
    background: var(--card-bg);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border-light);
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }
  .portfolio-card.hidden { display: none; }
  .portfolio-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.6);
    border-color: var(--border);
  }
  .portfolio-card-link {
    display: block;
    cursor: pointer;
  }
  .portfolio-img-wrap {
    aspect-ratio: 16/10;
    overflow: hidden;
    position: relative;
    background: var(--dark);
  }
  .portfolio-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    transition: transform 0.5s ease;
  }
  .portfolio-card:hover .portfolio-img-wrap img {
    transform: scale(1.05);
  }
  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10,10,10,0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .portfolio-card:hover .portfolio-overlay { opacity: 1; }
  .portfolio-visit {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid var(--gold);
    padding: 0.65rem 1.4rem;
    border-radius: 3px;
    transition: all 0.25s ease;
  }
  .portfolio-card:hover .portfolio-visit {
    background: var(--gold);
    color: var(--black);
  }

  /* INFO CARD */
  .portfolio-info {
    padding: 1.8rem;
  }
  .portfolio-cat {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.8rem;
  }
  .portfolio-info h3 {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 0.6rem;
    color: var(--white);
  }
  .portfolio-client {
    font-size: 0.8rem;
    color: var(--grey);
    margin-bottom: 0.5rem;
    font-style: italic;
  }
  .portfolio-desc {
    font-size: 0.85rem;
    color: var(--grey-light);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .portfolio-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--grey);
    background: rgba(255,255,255,0.04);
    padding: 0.3rem 0.7rem;
    border-radius: 3px;
    border: 1px solid var(--border-light);
  }

  /* CTA */
  .cta-section {
    padding: var(--pad-section);
    background: var(--anthracite);
    border-top: 1px solid var(--border);
  }
  .cta-inner {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .cta-inner h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    margin: 0.8rem 0 1.5rem;
  }
  .cta-inner p {
    font-size: 1rem;
    color: var(--grey);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }
  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .portfolio-hero { padding: 9rem 0 4rem; }
    .portfolio-grid { grid-template-columns: 1fr; }
    .filters-wrap { gap: 0.6rem; }
    .filter-btn { font-size: 0.68rem; padding: 0.55rem 1rem; }
  }
</style>

<script>
  // Système de filtrage
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.portfolio-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.getAttribute('data-filter');

        // Update active state
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Filter cards
        cards.forEach(card => {
          const category = card.getAttribute('data-category');
          if (filter === 'all' || category === filter) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });
  });
</script>

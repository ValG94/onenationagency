---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact — One Nation Agency"
  description="Contactez One Nation Agency pour discuter de votre projet de communication stratégique, d'agent IA ou de création web premium."
>
  <Header />

  <main id="main-content">

    <!-- HERO CONTACT -->
    <section class="contact-hero">
      <div class="container">
        <div class="contact-hero-content">
          <span class="label reveal">Contact</span>
          <div class="gold-bar reveal"></div>
          <h1 class="reveal reveal-delay-1">
            PARLONS DE<br />
            <span class="gold-text">VOTRE PROJET.</span>
          </h1>
          <p class="contact-lead reveal reveal-delay-2">
            Que vous ayez un projet précis ou une problématique à explorer, notre équipe est disponible pour vous accompagner. Chaque conversation commence par une écoute.
          </p>
        </div>
      </div>
    </section>

    <!-- CONTACT MAIN -->
    <section class="contact-main">
      <div class="container">
        <div class="contact-grid">

          <!-- FORMULAIRE -->
          <div class="contact-form-wrap reveal">
            <h2>Envoyez-nous un message</h2>
            <form class="contact-form" id="contactForm" novalidate>
              <div class="form-row">
                <div class="form-group">
                  <label for="firstName">Prénom *</label>
                  <input type="text" id="firstName" name="firstName" placeholder="Votre prénom" required />
                </div>
                <div class="form-group">
                  <label for="lastName">Nom *</label>
                  <input type="text" id="lastName" name="lastName" placeholder="Votre nom" required />
                </div>
              </div>
              <div class="form-group">
                <label for="email">Email professionnel *</label>
                <input type="email" id="email" name="email" placeholder="votre@email.com" required />
              </div>
              <div class="form-group">
                <label for="phone">Téléphone / WhatsApp</label>
                <input type="tel" id="phone" name="phone" placeholder="+33 6 XX XX XX XX" />
              </div>
              <div class="form-group">
                <label for="organization">Organisation / Entreprise</label>
                <input type="text" id="organization" name="organization" placeholder="Votre organisation" />
              </div>
              <div class="form-group">
                <label for="subject">Sujet de votre demande *</label>
                <select id="subject" name="subject" required>
                  <option value="" disabled selected>Sélectionnez un sujet</option>
                  <option value="communication">Communication stratégique & institutionnelle</option>
                  <option value="ia">Agent IA & Automatisation</option>
                  <option value="web">Création web & design</option>
                  <option value="campagne">Campagne politique</option>
                  <option value="crise">Gestion de crise</option>
                  <option value="autre">Autre demande</option>
                </select>
              </div>
              <div class="form-group">
                <label for="message">Votre message *</label>
                <textarea id="message" name="message" rows="5" placeholder="Décrivez votre projet ou votre problématique..." required></textarea>
              </div>
              <div class="form-group form-group--check">
                <label class="checkbox-label">
                  <input type="checkbox" name="consent" required />
                  <span>J'accepte que mes données soient utilisées pour traiter ma demande. <a href="/politique-de-confidentialite">Politique de confidentialité</a></span>
                </label>
              </div>
              <button type="submit" class="btn-gold btn-submit">
                <span class="btn-text">Envoyer le message</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
              <p class="form-note">Réponse garantie sous 24h ouvrées.</p>
            </form>
          </div>

          <!-- INFOS CONTACT -->
          <div class="contact-info reveal reveal-delay-2">
            <div class="contact-info-block">
              <h3>Nos coordonnées</h3>

              <div class="contact-item">
                <div class="contact-item-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.73a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
                  </svg>
                </div>
                <div>
                  <span class="contact-item-label">WhatsApp</span>
                  <a href="https://wa.me/33625523859" target="_blank" rel="noopener noreferrer" class="contact-item-value">+33 6 25 52 38 59</a>
                </div>
              </div>

              <div class="contact-item">
                <div class="contact-item-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                  </svg>
                </div>
                <div>
                  <span class="contact-item-label">Email</span>
                  <a href="mailto:contact@onenationagency.com" class="contact-item-value">contact@onenationagency.com</a>
                </div>
              </div>

              <div class="contact-item">
                <div class="contact-item-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div>
                  <span class="contact-item-label">Siège social</span>
                  <span class="contact-item-value">Paris, France</span>
                </div>
              </div>

              <div class="contact-item">
                <div class="contact-item-icon">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                  </svg>
                </div>
                <div>
                  <span class="contact-item-label">Présence</span>
                  <span class="contact-item-value">Paris · Afrique · International</span>
                </div>
              </div>
            </div>

            <div class="contact-whatsapp-card">
              <div class="wa-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-3.825 3.113-6.937 6.937-6.937 1.856.001 3.598.723 4.907 2.034 1.31 1.311 2.031 3.054 2.03 4.908-.001 3.825-3.113 6.938-6.937 6.938z"/>
                </svg>
              </div>
              <div>
                <h4>Réponse rapide garantie</h4>
                <p>Contactez-nous directement sur WhatsApp pour une réponse en moins de 2h.</p>
                <a href="https://wa.me/33625523859" target="_blank" rel="noopener noreferrer" class="btn-gold btn-sm">
                  Écrire sur WhatsApp
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </div>

            <div class="contact-disponibilite">
              <h4>Disponibilité</h4>
              <div class="dispo-grid">
                <div class="dispo-item">
                  <span class="dispo-day">Lun — Ven</span>
                  <span class="dispo-hours">9h00 — 19h00</span>
                </div>
                <div class="dispo-item">
                  <span class="dispo-day">Samedi</span>
                  <span class="dispo-hours">10h00 — 16h00</span>
                </div>
                <div class="dispo-item">
                  <span class="dispo-day">Urgences</span>
                  <span class="dispo-hours">24h/24 via WhatsApp</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* HERO */
  .contact-hero {
    padding: 12rem 0 5rem;
    background: linear-gradient(135deg, var(--black) 0%, var(--anthracite) 100%);
    border-bottom: 1px solid var(--border);
  }
  .contact-hero-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }
  .contact-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    margin: 1rem 0 1.5rem;
  }
  .contact-lead {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.85;
  }

  /* MAIN */
  .contact-main {
    padding: var(--pad-section);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: flex-start;
  }

  /* FORMULAIRE */
  .contact-form-wrap h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 2rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .form-group label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--grey-light);
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.85rem 1rem;
    color: var(--white);
    font-family: var(--font-body);
    font-size: 0.9rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
    outline: none;
    -webkit-appearance: none;
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--grey);
  }
  .form-group select {
    cursor: pointer;
    color: var(--grey);
  }
  .form-group select option { background: var(--dark); color: var(--white); }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(201,168,76,0.1);
  }
  .form-group textarea { resize: vertical; min-height: 120px; }

  .form-group--check { flex-direction: row; align-items: flex-start; }
  .checkbox-label {
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
    font-size: 0.82rem;
    color: var(--grey);
    line-height: 1.5;
    cursor: pointer;
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--font-body);
    font-weight: 400;
  }
  .checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 2px;
    accent-color: var(--gold);
    cursor: pointer;
  }
  .checkbox-label a { color: var(--gold); }

  .btn-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 1rem;
    font-size: 0.82rem;
  }
  .form-note {
    text-align: center;
    font-size: 0.78rem;
    color: var(--grey);
    margin-top: -0.5rem;
  }

  /* INFOS CONTACT */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .contact-info-block h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .contact-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border-light);
  }
  .contact-item:last-child { border-bottom: none; }
  .contact-item-icon {
    width: 36px;
    height: 36px;
    border-radius: 6px;
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    flex-shrink: 0;
  }
  .contact-item-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--grey);
    margin-bottom: 0.2rem;
  }
  .contact-item-value {
    font-size: 0.9rem;
    color: var(--white);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  a.contact-item-value:hover { color: var(--gold); }

  /* WHATSAPP CARD */
  .contact-whatsapp-card {
    background: rgba(37,211,102,0.06);
    border: 1px solid rgba(37,211,102,0.2);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .wa-icon { color: #25D366; flex-shrink: 0; margin-top: 2px; }
  .contact-whatsapp-card h4 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .contact-whatsapp-card p {
    font-size: 0.82rem;
    color: var(--grey);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .btn-sm {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    padding: 0.55rem 1rem;
  }

  /* DISPONIBILITÉ */
  .contact-disponibilite {
    background: var(--card-bg);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 1.5rem;
  }
  .contact-disponibilite h4 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .dispo-grid {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .dispo-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border-light);
    font-size: 0.85rem;
  }
  .dispo-item:last-child { border-bottom: none; }
  .dispo-day { color: var(--grey); }
  .dispo-hours { color: var(--white); font-weight: 600; }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .contact-hero { padding: 9rem 0 4rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Gestion du formulaire de contact
  const form = document.getElementById('contactForm') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector('.btn-submit') as HTMLButtonElement;
      const btnText = form.querySelector('.btn-text') as HTMLSpanElement;

      btn.disabled = true;
      btnText.textContent = 'Envoi en cours...';

      // Simulation d'envoi (à remplacer par EmailJS ou API)
      await new Promise(resolve => setTimeout(resolve, 1500));

      btnText.textContent = '✓ Message envoyé !';
      btn.style.background = '#2a9d5c';

      setTimeout(() => {
        form.reset();
        btnText.textContent = 'Envoyer le message';
        btn.disabled = false;
        btn.style.background = '';
      }, 3000);
    });
  }
</script>

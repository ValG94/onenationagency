---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLatestRealisations } from '../data/realisations';

const latestRealisations = getLatestRealisations(3);
---


<Layout
  title="One Nation Agency — Communication Stratégique, Agents IA & Web Premium"
  description="One Nation Agency — Agence premium spécialisée en communication stratégique institutionnelle, création d'agents IA sur mesure et développement web haut de gamme."
>
  <!-- SPLASH SCREEN -->
  <div class="splash" id="splash" aria-hidden="true">
    <!-- Particules lumineuses -->
    <div class="splash-particles" aria-hidden="true">
      <span class="particle" style="--px:15%;--py:20%;--pd:2.4s"></span>
      <span class="particle" style="--px:80%;--py:15%;--pd:3.1s"></span>
      <span class="particle" style="--px:50%;--py:75%;--pd:2.7s"></span>
      <span class="particle" style="--px:25%;--py:65%;--pd:3.8s"></span>
      <span class="particle" style="--px:70%;--py:55%;--pd:2.2s"></span>
      <span class="particle" style="--px:90%;--py:80%;--pd:4.0s"></span>
      <span class="particle" style="--px:10%;--py:85%;--pd:3.3s"></span>
    </div>
    <div class="splash-content">
      <!-- Logo -->
      <div class="splash-logo-wrap">
        <img src="/ON_white.png" alt="One Nation Agency" class="splash-logo-img" />
      </div>
      <!-- Titre monumental — version DESKTOP (une ligne) -->
      <div class="splash-title-row splash-title-desktop" id="splashTitle">
        <span class="sl" style="--i:0">O</span><span class="sl" style="--i:1">N</span><span class="sl" style="--i:2">E</span>
        <span class="sl sl-space"> </span>
        <span class="sl sl-gold" style="--i:3">N</span><span class="sl sl-gold" style="--i:4">A</span><span class="sl sl-gold" style="--i:5">T</span><span class="sl sl-gold" style="--i:6">I</span><span class="sl sl-gold" style="--i:7">O</span><span class="sl sl-gold" style="--i:8">N</span>
        <span class="sl sl-space"> </span>
        <span class="sl" style="--i:9">A</span><span class="sl" style="--i:10">G</span><span class="sl" style="--i:11">E</span><span class="sl" style="--i:12">N</span><span class="sl" style="--i:13">C</span><span class="sl" style="--i:14">Y</span>
      </div>
      <!-- Titre monumental — version MOBILE (deux lignes) -->
      <div class="splash-title-mobile" aria-hidden="true">
        <!-- Ligne 1 : ONE NATION -->
        <div class="splash-mobile-line splash-mobile-line-1">
          <span class="slm" style="--j:0">O</span><span class="slm" style="--j:1">N</span><span class="slm" style="--j:2">E</span>
          <span class="slm slm-space"> </span>
          <span class="slm slm-gold" style="--j:3">N</span><span class="slm slm-gold" style="--j:4">A</span><span class="slm slm-gold" style="--j:5">T</span><span class="slm slm-gold" style="--j:6">I</span><span class="slm slm-gold" style="--j:7">O</span><span class="slm slm-gold" style="--j:8">N</span>
        </div>
        <!-- Ligne 2 : AGENCY (décalage temporel) -->
        <div class="splash-mobile-line splash-mobile-line-2">
          <span class="slm slm-delay" style="--j:0">A</span><span class="slm slm-delay" style="--j:1">G</span><span class="slm slm-delay" style="--j:2">E</span><span class="slm slm-delay" style="--j:3">N</span><span class="slm slm-delay" style="--j:4">C</span><span class="slm slm-delay" style="--j:5">Y</span>
        </div>
      </div>
      <!-- Ligne dorée séparatrice — apparaît après les lettres -->
      <div class="splash-line-reveal" aria-hidden="true"></div>
      <!-- Tagline -->
      <p class="splash-tagline">La communication sur mesure</p>
    </div>
    <!-- Barre de chargement -->
    <div class="splash-bar"></div>
  </div>

  <!-- SITE PRINCIPAL -->
  <div class="site-wrapper" id="site-wrapper">
    <Header />

    <main id="main-content">

      <!-- ===== HERO ===== -->
      <section class="hero" id="hero">
        <div class="hero-video-wrap">
          <video
            class="hero-video"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            aria-hidden="true"
          >
            <source src="/presentationOneNation-compressed.mp4" type="video/mp4" />
          </video>
          <div class="hero-overlay"></div>
        </div>

        <div class="hero-content container">
          <div class="hero-badge reveal">
            <span class="label">Europe · Afrique · International</span>
          </div>
          <h1 class="hero-title reveal reveal-delay-1">
            L'EXCELLENCE<br />
            <span class="gold-text">STRATÉGIQUE.</span><br />
            L'INNOVATION<br />
            <span class="gold-text">DIGITALE.</span>
          </h1>
          <p class="hero-sub reveal reveal-delay-2">
            Nous accompagnons les institutions, les dirigeants et les organisations ambitieuses dans la maîtrise de leur image et la transformation de leur écosystème digital.
          </p>
          <div class="hero-actions reveal reveal-delay-3">
            <a href="/vision" class="btn-gold">
              Découvrir notre vision
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/contact" class="btn-outline">Nous contacter</a>
          </div>
        </div>

        <!-- Scroll indicator -->
        <div class="scroll-indicator" aria-hidden="true">
          <div class="scroll-line"></div>
          <span>Scroll</span>
        </div>
      </section>

      <!-- ===== STATS ===== -->
      <section class="stats-bar">
        <div class="container">
          <div class="stats-grid">
            <div class="stat-item reveal">
              <span class="stat-num">+50</span>
              <span class="stat-label">Projets livrés</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item reveal reveal-delay-1">
              <span class="stat-num">12+</span>
              <span class="stat-label">Pays couverts</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item reveal reveal-delay-2">
              <span class="stat-num">8</span>
              <span class="stat-label">Années d'expertise</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item reveal reveal-delay-3">
              <span class="stat-num">100%</span>
              <span class="stat-label">Clients satisfaits</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== 3 PILIERS ===== -->
      <section class="pillars" id="expertises">
        <div class="container">
          <div class="section-header reveal">
            <span class="label">Nos expertises</span>
            <div class="gold-bar"></div>
            <h2>TROIS EXPERTISES.<br />UNE VISION.</h2>
            <p class="section-intro">
              À la croisée du conseil stratégique, de l'intelligence artificielle et de la création digitale, One Nation Agency déploie une offre intégrée et sur mesure pour les acteurs qui comptent.
            </p>
          </div>

          <div class="pillars-grid">
            <!-- Pilier 1 -->
            <article class="pillar-card reveal reveal-delay-1">
              <div class="pillar-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M3 3h18v18H3z" rx="2"/>
                  <path d="M3 9h18M9 21V9"/>
                </svg>
              </div>
              <span class="pillar-num">01</span>
              <h3>Communication<br />Institutionnelle</h3>
              <p>Façonner l'opinion. Protéger votre réputation. Nous concevons des stratégies d'influence sur mesure pour les acteurs publics et privés de premier plan.</p>
              <a href="/conseil-strategique" class="pillar-link">
                Explorer
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </article>

            <!-- Pilier 2 -->
            <article class="pillar-card pillar-card--featured reveal reveal-delay-2">
              <div class="pillar-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="3"/>
                  <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
                </svg>
              </div>
              <span class="pillar-num">02</span>
              <h3>Agents IA &<br />Automatisation</h3>
              <p>L'intelligence artificielle au service de votre croissance. Des assistants virtuels sur mesure pour qualifier, convertir et servir vos audiences 24h/24.</p>
              <a href="/intelligence-artificielle" class="pillar-link">
                Explorer
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <div class="pillar-featured-badge">Premium</div>
            </article>

            <!-- Pilier 3 -->
            <article class="pillar-card reveal reveal-delay-3">
              <div class="pillar-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="3" width="20" height="14" rx="2"/>
                  <path d="M8 21h8M12 17v4"/>
                </svg>
              </div>
              <span class="pillar-num">03</span>
              <h3>Création Web<br />Premium</h3>
              <p>Des plateformes digitales immersives, performantes et mémorables. L'écrin technologique que mérite votre ambition.</p>
              <a href="/services" class="pillar-link">
                Explorer
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </article>
          </div>
        </div>
      </section>

      <!-- ===== SECTION AGENCE ===== -->
      <section class="agency-section">
        <div class="container">
          <div class="agency-grid">
            <div class="agency-visual reveal">
              <div class="agency-img-wrap">
                <img src="/agency_africa_v1.jpg" alt="One Nation Agency — Vision globale, ancrage africain" loading="lazy" />
                <div class="agency-img-overlay"></div>
              </div>
              <div class="agency-badge-float">
                <span class="label">Depuis 2016</span>
                <p>Europe · Afrique · International</p>
              </div>
            </div>
            <div class="agency-text">
              <span class="label reveal">L'Agence</span>
              <div class="gold-bar reveal"></div>
              <h2 class="reveal">UNE VISION GLOBALE.<br />UN ANCRAGE AFRICAIN.</h2>
              <p class="reveal reveal-delay-1">
                One Nation Agency n'est pas une simple agence de communication. Nous sommes les architectes de votre influence. À la croisée du conseil stratégique, des relations publiques et de l'innovation technologique, nous construisons des ponts entre les institutions, les marchés et les citoyens.
              </p>
              <p class="reveal reveal-delay-2">
                Notre compréhension fine des enjeux panafricains et internationaux nous permet de déployer des campagnes d'une précision chirurgicale, adaptées aux réalités culturelles et politiques de chaque territoire.
              </p>
              <div class="agency-actions reveal reveal-delay-3">
                <a href="/vision" class="btn-gold">
                  Notre vision
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
                <a href="/portfolio" class="btn-outline">Nos réalisations</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== PORTFOLIO APERÇU ===== -->
      <section class="portfolio-preview" id="portfolio">
        <div class="container">
          <div class="section-header reveal">
            <span class="label">Portfolio</span>
            <div class="gold-bar"></div>
            <h2>NOS DERNIÈRES<br />RÉALISATIONS.</h2>
          </div>

          <div class="portfolio-grid">
            {latestRealisations.map((r, i) => (
              <article class={`portfolio-card reveal reveal-delay-${i + 1}`}>
                {r.url ? (
                  <a href={r.url} target="_blank" rel="noopener noreferrer" class="portfolio-card-link">
                    <div class="portfolio-img-wrap">
                      <img
                        src={r.image}
                        alt={r.imageAlt}
                        loading="lazy"
                        style={r.imagePosition && r.imagePosition !== 'center' ? `object-position: ${r.imagePosition}` : ''}
                      />
                      <div class="portfolio-overlay">
                        <span class="portfolio-visit">Voir le projet</span>
                      </div>
                    </div>
                    <div class="portfolio-info">
                      <span class="portfolio-cat">{r.category}</span>
                      <h3>{r.title}</h3>
                      <p>{r.description}</p>
                    </div>
                  </a>
                ) : (
                  <div class="portfolio-card-link">
                    <div class="portfolio-img-wrap">
                      <img
                        src={r.image}
                        alt={r.imageAlt}
                        loading="lazy"
                        style={r.imagePosition && r.imagePosition !== 'center' ? `object-position: ${r.imagePosition}` : ''}
                      />
                      <div class="portfolio-overlay">
                        <span class="portfolio-visit">Voir le projet</span>
                      </div>
                    </div>
                    <div class="portfolio-info">
                      <span class="portfolio-cat">{r.category}</span>
                      <h3>{r.title}</h3>
                      <p>{r.description}</p>
                    </div>
                  </div>
                )}
              </article>
            ))}
          </div>

          <div class="portfolio-cta reveal">
            <a href="/portfolio" class="btn-outline">
              Voir toutes nos réalisations
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- ===== CTA FINAL ===== -->
      <section class="cta-section">
        <div class="container">
          <div class="cta-inner reveal">
            <span class="label">Prêt à démarrer ?</span>
            <h2>PARLONS DE<br /><span class="gold-text">VOTRE PROJET.</span></h2>
            <p>Que vous ayez besoin d'une stratégie de communication, d'un agent IA ou d'une plateforme digitale premium, notre équipe est prête à vous accompagner.</p>
            <div class="cta-actions">
              <a href="/contact" class="btn-gold">
                Nous contacter
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="https://wa.me/33625523859" target="_blank" rel="noopener noreferrer" class="btn-outline">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-3.825 3.113-6.937 6.937-6.937 1.856.001 3.598.723 4.907 2.034 1.31 1.311 2.031 3.054 2.03 4.908-.001 3.825-3.113 6.938-6.937 6.938z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <Footer />

    <!-- WhatsApp flottant -->
    <a href="https://wa.me/33625523859" class="whatsapp-btn" target="_blank" rel="noopener noreferrer" aria-label="Nous contacter sur WhatsApp">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-3.825 3.113-6.937 6.937-6.937 1.856.001 3.598.723 4.907 2.034 1.31 1.311 2.031 3.054 2.03 4.908-.001 3.825-3.113 6.938-6.937 6.938z"/>
      </svg>
    </a>
  </div>
</Layout>

<style>
  /* ===== SPLASH PREMIUM ===== */
  .splash {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at 50% 40%, #111111 0%, #050505 60%, #000000 100%);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    overflow: hidden;
    transition: opacity 1s cubic-bezier(0.4,0,0.2,1), visibility 1s ease;
  }
  .splash.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* Particules dorées flottantes */
  .splash-particles { position: absolute; inset: 0; pointer-events: none; }
  .particle {
    position: absolute;
    left: var(--px);
    top: var(--py);
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(184,150,80,0.8) 0%, transparent 70%);
    animation: particleDrift var(--pd) ease-in-out infinite alternate;
    opacity: 0;
    animation-delay: calc(var(--pd) * 0.3);
  }
  @keyframes particleDrift {
    0%   { opacity: 0; transform: translateY(0) scale(1); }
    30%  { opacity: 0.6; }
    70%  { opacity: 0.4; }
    100% { opacity: 0; transform: translateY(-20px) scale(1.5); }
  }

  /* Ligne dorée séparatrice — effet balayage après les lettres */
  .splash-line-reveal {
    position: relative;
    height: 1px;
    width: 100%;
    overflow: hidden;
    align-self: stretch;
    opacity: 0;
    animation: lineAppear 0.1s ease 2.0s forwards;
  }
  .splash-line-reveal::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 0%, rgba(184,150,80,0.5) 20%, rgba(212,175,55,0.9) 50%, rgba(184,150,80,0.5) 80%, transparent 100%);
    box-shadow: 0 0 8px rgba(184,150,80,0.4);
    transform: translateX(-100%);
    animation: lineSweep 1.1s cubic-bezier(0.4,0,0.2,1) 2.05s forwards;
  }
  @keyframes lineAppear {
    to { opacity: 1; }
  }
  @keyframes lineSweep {
    to { transform: translateX(0); }
  }

  /* Contenu central */
  .splash-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.8rem;
  }

  /* Logo */
  .splash-logo-wrap {
    opacity: 0;
    transform: scale(0.85);
    animation: logoReveal 0.7s cubic-bezier(0.22,1,0.36,1) 0.5s forwards;
    filter: drop-shadow(0 0 20px rgba(184,150,80,0.35)) drop-shadow(0 2px 8px rgba(0,0,0,0.8));
  }
  .splash-logo-img {
    height: 72px;
    width: auto;
    display: block;
  }
  @keyframes logoReveal {
    to { opacity: 1; transform: scale(1); }
  }

  /* Titre monumental sur une ligne */
  .splash-title-row {
    display: flex;
    align-items: baseline;
    gap: 0;
    line-height: 0.9;
    perspective: 800px;
  }

  /* Chaque lettre */
  .sl {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 8.5vw, 7.5rem);
    font-weight: 900;
    letter-spacing: 0.04em;
    display: inline-block;
    opacity: 0;
    transform: translateY(18px);
    animation: slIn 0.9s cubic-bezier(0.16,1,0.3,1) calc(0.6s + var(--i, 0) * 0.07s) forwards;
    /* Métal gunmetal / chrome sombre avec reflets */
    background: linear-gradient(
      160deg,
      #9a9a9a 0%,
      #d8d8d8 15%,
      #f0f0f0 25%,
      #b0b0b0 35%,
      #787878 50%,
      #c0c0c0 60%,
      #e8e8e8 70%,
      #a0a0a0 80%,
      #686868 90%,
      #b8b8b8 100%
    );
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-shadow: none;
    animation:
      slIn 0.9s cubic-bezier(0.16,1,0.3,1) calc(0.6s + var(--i, 0) * 0.07s) forwards,
               chromeSweep 4s ease-in-out 2.5s infinite;
    /* Ombre 3D simulée */

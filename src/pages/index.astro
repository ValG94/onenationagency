    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 4px 16px rgba(184,150,80,0.5)) drop-shadow(0 1px 0 rgba(255,220,80,0.15));
    animation:
      slIn 0.9s cubic-bezier(0.16,1,0.3,1) calc(0.6s + var(--i, 0) * 0.07s) forwards,
               goldSweep 3.5s ease-in-out 2.8s infinite;

---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Expertises — One Nation Agency"
  description="Communication stratégique institutionnelle, agents IA sur mesure, création web premium. Découvrez les expertises de One Nation Agency."
>
  <Header />

  <main id="main-content">

    <!-- HERO SERVICES -->
    <section class="services-hero">
      <div class="container">
        <div class="services-hero-content">
          <span class="label reveal">Expertises</span>
          <div class="gold-bar reveal"></div>
          <h1 class="reveal reveal-delay-1">
            UNE OFFRE INTÉGRÉE<br />
            <span class="gold-text">POUR LES ACTEURS QUI COMPTENT.</span>
          </h1>
          <p class="services-lead reveal reveal-delay-2">
            Trois expertises complémentaires, une vision unifiée. Nous intervenons à chaque étape de votre transformation stratégique et digitale.
          </p>
        </div>
      </div>
    </section>

    <!-- SERVICE 1 — COMMUNICATION -->
    <section class="service-block" id="communication">
      <div class="container">
        <div class="service-grid">
          <div class="service-content">
            <span class="service-num">01</span>
            <span class="label reveal">Communication Stratégique</span>
            <div class="gold-bar reveal"></div>
            <h2 class="reveal">FAÇONNER L'OPINION.<br />PROTÉGER L'IMAGE.</h2>
            <p class="reveal reveal-delay-1">
              Dans l'arène politique et institutionnelle, la communication n'est pas un accessoire — c'est une arme stratégique. Nous concevons des stratégies d'influence sur mesure pour les acteurs publics et privés qui veulent maîtriser leur narratif.
            </p>

            <div class="service-features reveal reveal-delay-2">
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                  </svg>
                </div>
                <div>
                  <h4>Stratégie de communication globale</h4>
                  <p>Définition du positionnement, des messages clés et des canaux d'influence adaptés à votre cible.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                </div>
                <div>
                  <h4>Gestion de crise & e-réputation</h4>
                  <p>Anticipation, détection et gestion des crises médiatiques et digitales en temps réel.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                  </svg>
                </div>
                <div>
                  <h4>Campagnes institutionnelles & politiques</h4>
                  <p>Conception et déploiement de campagnes électorales, de lobbying et de relations publiques.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                </div>
                <div>
                  <h4>Relations presse & influence</h4>
                  <p>Réseau de journalistes, d'influenceurs et de leaders d'opinion en Afrique et en Europe.</p>
                </div>
              </div>
            </div>

            <div class="service-cta reveal reveal-delay-3">
              <a href="/contact" class="btn-gold">
                Discuter de votre projet
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="service-visual reveal">
            <div class="service-img-wrap">
              <img src="/service_communication.jpg" alt="Communication stratégique — One Nation Agency" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DIVIDER -->
    <div class="service-divider"></div>

    <!-- SERVICE 2 — IA -->
    <section class="service-block service-block--reverse" id="ia">
      <div class="container">
        <div class="service-grid">
          <div class="service-visual reveal">
            <div class="service-img-wrap">
              <img src="/service_ia.jpg" alt="Intelligence Artificielle — One Nation Agency" loading="lazy" />
            </div>
          </div>

          <div class="service-content">
            <span class="service-num">02</span>
            <span class="label reveal">Intelligence Artificielle</span>
            <div class="gold-bar reveal"></div>
            <h2 class="reveal">L'IA QUI TRAVAILLE<br />POUR VOUS.</h2>
            <p class="reveal reveal-delay-1">
              Nous créons des agents IA conversationnels sur mesure, formés sur votre domaine d'expertise et intégrés à vos outils existants. Ils qualifient vos prospects, répondent à vos clients et automatisent vos processus — 24h/24, sans interruption.
            </p>

            <div class="service-features reveal reveal-delay-2">
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                  </svg>
                </div>
                <div>
                  <h4>Agents conversationnels multilingues</h4>
                  <p>Français, anglais, arabe et langues africaines — vos clients sont servis dans leur langue.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
                  </svg>
                </div>
                <div>
                  <h4>Intégration WhatsApp, Messenger, Web</h4>
                  <p>Déployé sur tous vos canaux de communication existants sans friction technique.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                  </svg>
                </div>
                <div>
                  <h4>Analytics & reporting en temps réel</h4>
                  <p>Dashboard complet pour suivre les performances, les conversations et les conversions.</p>
                </div>
              </div>
            </div>

            <div class="service-cta reveal reveal-delay-3">
              <a href="/intelligence-artificielle" class="btn-gold">
                En savoir plus sur nos agents IA
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- DIVIDER -->
    <div class="service-divider"></div>

    <!-- SERVICE 3 — WEB -->
    <section class="service-block" id="web">
      <div class="container">
        <div class="service-grid">
          <div class="service-content">
            <span class="service-num">03</span>
            <span class="label reveal">Création Web Premium</span>
            <div class="gold-bar reveal"></div>
            <h2 class="reveal">L'ÉCRIN DIGITAL<br />QUE VOUS MÉRITEZ.</h2>
            <p class="reveal reveal-delay-1">
              Votre présence digitale est votre première impression. Nous créons des plateformes web immersives, performantes et mémorables qui reflètent l'excellence de votre organisation et convertissent vos visiteurs en clients.
            </p>

            <div class="service-features reveal reveal-delay-2">
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <path d="M8 21h8M12 17v4"/>
                  </svg>
                </div>
                <div>
                  <h4>Sites institutionnels & corporate</h4>
                  <p>Design premium, animations fluides et expérience utilisateur irréprochable pour les organisations de premier plan.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 01-8 0"/>
                  </svg>
                </div>
                <div>
                  <h4>Plateformes e-commerce & B2B</h4>
                  <p>Solutions de vente en ligne robustes, intégration de paiements africains et internationaux.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
                  </svg>
                </div>
                <div>
                  <h4>Design graphique & identité visuelle</h4>
                  <p>Création de logo, charte graphique, supports de communication — une identité cohérente et mémorable.</p>
                </div>
              </div>
            </div>

            <div class="service-cta reveal reveal-delay-3">
              <a href="/contact" class="btn-gold">
                Lancer mon projet web
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="service-visual reveal">
            <div class="service-img-wrap">
              <img src="/service_web.jpg" alt="Création web premium — One Nation Agency" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-inner reveal">
          <span class="label">Prêt à démarrer ?</span>
          <h2>PARLONS DE<br /><span class="gold-text">VOTRE PROJET.</span></h2>
          <p>Quelle que soit votre problématique, notre équipe pluridisciplinaire saura vous proposer la solution la plus adaptée à vos objectifs.</p>
          <div class="cta-actions">
            <a href="/contact" class="btn-gold">
              Nous contacter
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/portfolio" class="btn-outline">Voir nos réalisations</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* HERO */
  .services-hero {
    padding: 12rem 0 5rem;
    background: linear-gradient(135deg, var(--black) 0%, var(--anthracite) 100%);
    border-bottom: 1px solid var(--border);
  }
  .services-hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }
  .services-hero h1 {
    font-size: clamp(2.2rem, 4.5vw, 4rem);
    margin: 1rem 0 1.5rem;
  }
  .services-lead {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.85;
    max-width: 680px;
    margin: 0 auto;
  }

  /* SERVICE BLOCKS */
  .service-block {
    padding: var(--pad-section);
  }
  .service-block:nth-child(even) {
    background: var(--anthracite);
  }
  .service-divider {
    height: 1px;
    background: var(--border-light);
  }
  .service-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .service-block--reverse .service-grid {
    direction: rtl;
  }
  .service-block--reverse .service-grid > * {
    direction: ltr;
  }

  .service-num {
    display: block;
    font-family: var(--font-display);
    font-size: 4rem;
    font-weight: 900;
    color: rgba(201,168,76,0.1);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .service-content h2 {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    margin-bottom: 1.5rem;
  }
  .service-content > p {
    font-size: 0.98rem;
    line-height: 1.85;
    color: var(--grey-light);
    margin-bottom: 2rem;
  }

  /* FEATURES */
  .service-features {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .service-feature {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .feature-icon {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    background: rgba(201,168,76,0.08);
    border: 1px solid rgba(201,168,76,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gold);
    flex-shrink: 0;
  }
  .service-feature h4 {
    font-size: 0.92rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
    color: var(--white);
  }
  .service-feature p {
    font-size: 0.85rem;
    color: var(--grey);
    line-height: 1.6;
  }

  /* VISUALS */
  .service-visual { display: flex; justify-content: center; }
  .service-img-wrap {
    border-radius: 8px;
    overflow: hidden;
    width: 100%;
    aspect-ratio: 4/5;
    background: var(--card-bg);
  }
  .service-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }
  .service-img-wrap:hover img { transform: scale(1.03); }
  .service-img-wrap--dark {
    background: var(--card-bg);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  /* AI VISUAL CARD */
  .ai-visual-card {
    background: var(--dark);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    max-width: 340px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
  .ai-visual-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1rem 1.2rem;
    background: rgba(201,168,76,0.06);
    border-bottom: 1px solid var(--border);
  }
  .ai-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--gold);
    animation: pulseGold 2s ease-in-out infinite;
  }
  .ai-visual-header span {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--gold);
  }
  .ai-visual-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .ai-visual-stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .ai-visual-num {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
  }
  .ai-visual-label {
    font-size: 0.75rem;
    color: var(--grey);
  }

  /* CTA */
  .cta-section {
    padding: var(--pad-section);
    background: var(--anthracite);
    border-top: 1px solid var(--border);
  }
  .cta-inner {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }
  .cta-inner h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    margin: 0.8rem 0 1.5rem;
  }
  .cta-inner p {
    font-size: 1rem;
    color: var(--grey);
    line-height: 1.8;
    margin-bottom: 2.5rem;
  }
  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .service-grid { grid-template-columns: 1fr; gap: 3rem; }
    .service-block--reverse .service-grid { direction: ltr; }
  }
  @media (max-width: 768px) {
    .services-hero { padding: 9rem 0 4rem; }
  }
</style>

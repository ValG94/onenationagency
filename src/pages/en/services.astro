---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---


<Layout
  title="Expertise — One Nation Agency"
  description="Institutional strategic communication, custom AI agents, premium web creation. Discover One Nation Agency's expertise."
>
  <Header lang="en" />

  <main id="main-content">

    <!-- HERO SERVICES -->
    <section class="services-hero">
      <div class="container">
        <div class="services-hero-content">
          <span class="label reveal">Expertise</span>
          <div class="gold-bar reveal"></div>
          <h1 class="reveal reveal-delay-1">
            AN INTEGRATED OFFER<br />
            <span class="gold-text">FOR THE PLAYERS WHO MATTER.</span>
          </h1>
          <p class="services-lead reveal reveal-delay-2">
            Three complementary areas of expertise, one unified vision. We intervene at every stage of your strategic and digital transformation.
          </p>
        </div>
      </div>
    </section>

    <!-- SERVICE 1 — COMMUNICATION -->
    <section class="service-block" id="communication">
      <div class="container">
        <div class="service-grid">
          <div class="service-content">
            <span class="service-num">01</span>
            <span class="label reveal">Strategic Communication</span>
            <div class="gold-bar reveal"></div>
            <h2 class="reveal">SHAPE OPINION.<br />PROTECT YOUR IMAGE.</h2>
            <p class="reveal reveal-delay-1">
              In the political and institutional arena, communication is not an accessory — it is a strategic weapon. We design tailored influence strategies for public and private actors who want to master their narrative.
            </p>

            <div class="service-features reveal reveal-delay-2">
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                  </svg>
                </div>
                <div>
                  <h4>Global communication strategy</h4>
                  <p>Defining positioning, key messages and influence channels tailored to your target audience.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                </div>
                <div>
                  <h4>Crisis management & e-reputation</h4>
                  <p>Anticipation, detection and real-time management of media and digital crises.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                  </svg>
                </div>
                <div>
                  <h4>Institutional & political campaigns</h4>
                  <p>Design and deployment of electoral campaigns, lobbying and public relations.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                </div>
                <div>
                  <h4>Press relations & influence</h4>
                  <p>Network of journalists, influencers and opinion leaders across Africa and Europe.</p>
                </div>
              </div>
            </div>

            <div class="service-cta reveal reveal-delay-3">
              <a href="/contact" class="btn-gold">
                Discuss your project
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="service-visual reveal">
            <div class="service-img-wrap">
              <img src="/service_communication.jpg" alt="Strategic Communication — One Nation Agency" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="service-divider"></div>

    <!-- SERVICE 2 — AI -->
    <section class="service-block service-block--reverse" id="ia">
      <div class="container">
        <div class="service-grid">
          <div class="service-visual reveal">
            <div class="service-img-wrap service-img-wrap--dark">
              <div class="ai-visual-card">
                <div class="ai-visual-header">
                  <div class="ai-dot"></div>
                  <span>AI Agent online</span>
                </div>
                <div class="ai-visual-body">
                  <div class="ai-visual-stat">
                    <span class="ai-visual-num">1,247</span>
                    <span class="ai-visual-label">Conversations this month</span>
                  </div>
                  <div class="ai-visual-stat">
                    <span class="ai-visual-num">89%</span>
                    <span class="ai-visual-label">Resolution rate</span>
                  </div>
                  <div class="ai-visual-stat">
                    <span class="ai-visual-num">+34%</span>
                    <span class="ai-visual-label">Qualified leads</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="service-content">
            <span class="service-num">02</span>
            <span class="label reveal">Artificial Intelligence</span>
            <div class="gold-bar reveal"></div>
            <h2 class="reveal">THE AI THAT WORKS<br />FOR YOU.</h2>
            <p class="reveal reveal-delay-1">
              We create custom conversational AI agents, trained on your area of expertise and integrated with your existing tools. They qualify your prospects, respond to your clients and automate your processes — 24/7, without interruption.
            </p>

            <div class="service-features reveal reveal-delay-2">
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                  </svg>
                </div>
                <div>
                  <h4>Multilingual conversational agents</h4>
                  <p>French, English, Arabic and African languages — your clients are served in their own language.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
                  </svg>
                </div>
                <div>
                  <h4>WhatsApp, Messenger & Web integration</h4>
                  <p>Deployed across all your existing communication channels without technical friction.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                  </svg>
                </div>
                <div>
                  <h4>Real-time analytics & reporting</h4>
                  <p>Comprehensive dashboard to track performance, conversations and conversions.</p>
                </div>
              </div>
            </div>

            <div class="service-cta reveal reveal-delay-3">
              <a href="/intelligence-artificielle" class="btn-gold">
                Learn more about our AI agents
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="service-divider"></div>

    <!-- SERVICE 3 — WEB -->
    <section class="service-block" id="web">
      <div class="container">
        <div class="service-grid">
          <div class="service-content">
            <span class="service-num">03</span>
            <span class="label reveal">Premium Web Creation</span>
            <div class="gold-bar reveal"></div>
            <h2 class="reveal">THE DIGITAL SETTING<br />YOU DESERVE.</h2>
            <p class="reveal reveal-delay-1">
              Your digital presence is your first impression. We create immersive, high-performance and memorable web platforms that reflect the excellence of your organisation and convert your visitors into clients.
            </p>

            <div class="service-features reveal reveal-delay-2">
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <path d="M8 21h8M12 17v4"/>
                  </svg>
                </div>
                <div>
                  <h4>Institutional & corporate websites</h4>
                  <p>Premium design, fluid animations and impeccable user experience for leading organisations.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <path d="M16 10a4 4 0 01-8 0"/>
                  </svg>
                </div>
                <div>
                  <h4>E-commerce & B2B platforms</h4>
                  <p>Robust online sales solutions, integration of African and international payment systems.</p>
                </div>
              </div>
              <div class="service-feature">
                <div class="feature-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
                  </svg>
                </div>
                <div>
                  <h4>Graphic design & visual identity</h4>
                  <p>Logo creation, brand guidelines, communication materials — a coherent and memorable identity.</p>
                </div>
              </div>
            </div>

            <div class="service-cta reveal reveal-delay-3">
              <a href="/contact" class="btn-gold">
                Launch my web project
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <div class="service-visual reveal">
            <div class="service-img-wrap">
              <img src="/service_web.jpg" alt="Premium Web Creation — One Nation Agency" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-inner reveal">
          <span class="label">Ready to start?</span>
          <h2>LET'S TALK ABOUT<br /><span class="gold-text">YOUR PROJECT.</span></h2>
          <p>Whatever your challenge, our multidisciplinary team will offer you the most appropriate solution for your objectives.</p>
          <div class="cta-actions">
            <a href="/contact" class="btn-gold">
              Contact us
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/portfolio" class="btn-outline">View our work</a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .services-hero { padding: 12rem 0 5rem; background: linear-gradient(135deg, var(--black) 0%, var(--anthracite) 100%); border-bottom: 1px solid var(--border); }
  .services-hero-content { max-width: 800px; margin: 0 auto; text-align: center; }
  .services-hero h1 { font-size: clamp(2.2rem, 4.5vw, 4rem); margin: 1rem 0 1.5rem; }
  .services-lead { font-size: 1.1rem; color: rgba(255,255,255,0.8); line-height: 1.85; max-width: 680px; margin: 0 auto; }
  .service-block { padding: var(--pad-section); }
  .service-block:nth-child(even) { background: var(--anthracite); }
  .service-divider { height: 1px; background: var(--border-light); }
  .service-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .service-block--reverse .service-grid { direction: rtl; }
  .service-block--reverse .service-grid > * { direction: ltr; }
  .service-num { display: block; font-family: var(--font-display); font-size: 4rem; font-weight: 900; color: rgba(201,168,76,0.1); line-height: 1; margin-bottom: 0.5rem; }
  .service-content h2 { font-size: clamp(1.8rem, 3vw, 2.8rem); margin-bottom: 1.5rem; }
  .service-content > p { font-size: 0.98rem; line-height: 1.85; color: var(--grey-light); margin-bottom: 2rem; }
  .service-features { display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 2.5rem; }
  .service-feature { display: flex; gap: 1rem; align-items: flex-start; }
  .feature-icon { width: 40px; height: 40px; border-radius: 6px; background: rgba(201,168,76,0.08); border: 1px solid rgba(201,168,76,0.15); display: flex; align-items: center; justify-content: center; color: var(--gold); flex-shrink: 0; }
  .service-feature h4 { font-size: 0.92rem; font-weight: 700; margin-bottom: 0.3rem; color: var(--white); }
  .service-feature p { font-size: 0.85rem; color: var(--grey); line-height: 1.6; }
  .service-visual { display: flex; justify-content: center; }
  .service-img-wrap { border-radius: 8px; overflow: hidden; width: 100%; aspect-ratio: 4/5; background: var(--card-bg); }
  .service-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
  .service-img-wrap:hover img { transform: scale(1.03); }
  .service-img-wrap--dark { background: var(--card-bg); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; padding: 2rem; }
  .ai-visual-card { background: var(--dark); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; width: 100%; max-width: 340px; box-shadow: 0 20px 60px rgba(0,0,0,0.5); }
  .ai-visual-header { display: flex; align-items: center; gap: 0.8rem; padding: 1rem 1.2rem; background: rgba(201,168,76,0.06); border-bottom: 1px solid var(--border); }
  .ai-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold); animation: pulseGold 2s ease-in-out infinite; }
  .ai-visual-header span { font-family: var(--font-display); font-size: 0.75rem; font-weight: 600; color: var(--gold); }
  .ai-visual-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 1.2rem; }
  .ai-visual-stat { display: flex; flex-direction: column; gap: 0.2rem; }
  .ai-visual-num { font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--gold); line-height: 1; }
  .ai-visual-label { font-size: 0.75rem; color: var(--grey); }
  .cta-section { padding: var(--pad-section); background: var(--anthracite); border-top: 1px solid var(--border); }
  .cta-inner { text-align: center; max-width: 700px; margin: 0 auto; }
  .cta-inner h2 { font-size: clamp(2rem, 4vw, 3.5rem); margin: 0.8rem 0 1.5rem; }
  .cta-inner p { font-size: 1rem; color: var(--grey); line-height: 1.8; margin-bottom: 2.5rem; }
  .cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  @media (max-width: 1024px) {
    .service-grid { grid-template-columns: 1fr; gap: 3rem; }
    .service-block--reverse .service-grid { direction: ltr; }
  }
  @media (max-width: 768px) { .services-hero { padding: 9rem 0 4rem; } }
</style>

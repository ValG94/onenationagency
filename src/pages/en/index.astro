---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---


<Layout
  title="One Nation Agency — Strategic Communication, AI Agents & Premium Web"
  description="One Nation Agency — Premium agency specializing in institutional strategic communication, custom AI agents and high-end web development."
  lang="en"
  canonical="/en"
>
  <!-- SPLASH SCREEN -->
  <div class="splash" id="splash" aria-hidden="true">
    <div class="splash-content">
      <div class="splash-logo">
        <img src="/logoOnenation.png" alt="One Nation Agency" />
      </div>
      <div class="splash-text">
        <span class="splash-word" data-word="ONE">ONE</span>
        <span class="splash-word" data-word="NATION">NATION</span>
        <span class="splash-word" data-word="AGENCY">AGENCY</span>
      </div>
      <p class="splash-tagline">Tailored Communication</p>
    </div>
    <div class="splash-bar"></div>
  </div>

  <!-- MAIN SITE -->
  <div class="site-wrapper" id="site-wrapper">
    <Header lang="en" />

    <main id="main-content">

      <!-- ===== HERO ===== -->
      <section class="hero" id="hero">
        <div class="hero-video-wrap">
          <video
            class="hero-video"
            autoplay
            muted
            loop
            playsinline
            preload="auto"
            aria-hidden="true"
          >
            <source src="/presentationOneNation-compressed.mp4" type="video/mp4" />
          </video>
          <div class="hero-overlay"></div>
        </div>

        <div class="hero-content container">
          <div class="hero-badge reveal">
            <span class="label">Paris · Africa · International</span>
          </div>
          <h1 class="hero-title reveal reveal-delay-1">
            STRATEGIC<br />
            <span class="gold-text">EXCELLENCE.</span><br />
            DIGITAL<br />
            <span class="gold-text">INNOVATION.</span>
          </h1>
          <p class="hero-sub reveal reveal-delay-2">
            We support institutions, leaders and ambitious organizations in mastering their image and transforming their digital ecosystem.
          </p>
          <div class="hero-actions reveal reveal-delay-3">
            <a href="/en/vision" class="btn-gold">
              Discover our vision
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="/en/contact" class="btn-outline">Contact us</a>
          </div>
        </div>

        <!-- Scroll indicator -->
        <div class="scroll-indicator" aria-hidden="true">
          <div class="scroll-line"></div>
          <span>Scroll</span>
        </div>
      </section>

      <!-- ===== STATS ===== -->
      <section class="stats-bar">
        <div class="container">
          <div class="stats-grid">
            <div class="stat-item reveal">
              <span class="stat-num">+50</span>
              <span class="stat-label">Projects delivered</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item reveal reveal-delay-1">
              <span class="stat-num">12+</span>
              <span class="stat-label">Countries covered</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item reveal reveal-delay-2">
              <span class="stat-num">8</span>
              <span class="stat-label">Years of expertise</span>
            </div>
            <div class="stat-divider" aria-hidden="true"></div>
            <div class="stat-item reveal reveal-delay-3">
              <span class="stat-num">100%</span>
              <span class="stat-label">Satisfied clients</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== 3 PILLARS ===== -->
      <section class="pillars" id="expertises">
        <div class="container">
          <div class="section-header reveal">
            <span class="label">Our expertise</span>
            <div class="gold-bar"></div>
            <h2>THREE EXPERTISES.<br />ONE VISION.</h2>
            <p class="section-intro">
              At the crossroads of strategic consulting, artificial intelligence and digital creation, One Nation Agency deploys an integrated, tailored offering for the players who matter.
            </p>
          </div>

          <div class="pillars-grid">
            <!-- Pillar 1 -->
            <article class="pillar-card reveal reveal-delay-1">
              <div class="pillar-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M3 3h18v18H3z" rx="2"/>
                  <path d="M3 9h18M9 21V9"/>
                </svg>
              </div>
              <span class="pillar-num">01</span>
              <h3>Institutional<br />Communication</h3>
              <p>Shape opinion. Protect your reputation. We design tailored influence strategies for leading public and private actors.</p>
              <a href="/services" class="pillar-link">
                Explore
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </article>

            <!-- Pillar 2 -->
            <article class="pillar-card pillar-card--featured reveal reveal-delay-2">
              <div class="pillar-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="3"/>
                  <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
                </svg>
              </div>
              <span class="pillar-num">02</span>
              <h3>AI Agents &<br />Automation</h3>
              <p>Artificial intelligence at the service of your growth. Custom virtual assistants to qualify, convert and serve your audiences 24/7.</p>
              <a href="/intelligence-artificielle" class="pillar-link">
                Explore
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <div class="pillar-featured-badge">Premium</div>
            </article>

            <!-- Pillar 3 -->
            <article class="pillar-card reveal reveal-delay-3">
              <div class="pillar-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="3" width="20" height="14" rx="2"/>
                  <path d="M8 21h8M12 17v4"/>
                </svg>
              </div>
              <span class="pillar-num">03</span>
              <h3>Premium Web<br />Creation</h3>
              <p>Immersive, high-performance and memorable digital platforms. The technological setting your ambition deserves.</p>
              <a href="/services" class="pillar-link">
                Explore
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </article>
          </div>
        </div>
      </section>

      <!-- ===== AGENCY SECTION ===== -->
      <section class="agency-section">
        <div class="container">
          <div class="agency-grid">
            <div class="agency-visual reveal">
              <div class="agency-img-wrap">
                <img src="/team_vision.jpg" alt="One Nation Agency — African Team" loading="lazy" />
                <div class="agency-img-overlay"></div>
              </div>
              <div class="agency-badge-float">
                <span class="label">Since 2016</span>
                <p>Paris · Africa · International</p>
              </div>
            </div>
            <div class="agency-text">
              <span class="label reveal">The Agency</span>
              <div class="gold-bar reveal"></div>
              <h2 class="reveal">A GLOBAL VISION.<br />AN AFRICAN ANCHOR.</h2>
              <p class="reveal reveal-delay-1">
                One Nation Agency is not just a communication agency. We are the architects of your influence. At the crossroads of strategic consulting, public relations and technological innovation, we build bridges between institutions, markets and citizens.
              </p>
              <p class="reveal reveal-delay-2">
                Our deep understanding of pan-African and international issues allows us to deploy campaigns with surgical precision, adapted to the cultural and political realities of each territory.
              </p>
              <div class="agency-actions reveal reveal-delay-3">
                <a href="/vision" class="btn-gold">
                  Our vision
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
                <a href="/portfolio" class="btn-outline">Our work</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== PORTFOLIO PREVIEW ===== -->
      <section class="portfolio-preview" id="portfolio">
        <div class="container">
          <div class="section-header reveal">
            <span class="label">Portfolio</span>
            <div class="gold-bar"></div>
            <h2>OUR LATEST<br />PROJECTS.</h2>
          </div>

          <div class="portfolio-grid">
            <article class="portfolio-card reveal reveal-delay-1">
              <a href="https://afac26.com" target="_blank" rel="noopener noreferrer" class="portfolio-card-link">
                <div class="portfolio-img-wrap">
                  <img src="/Afac26_home.jpg" alt="AFAC26 — Trilingual site and AI agent" loading="lazy" />
                  <div class="portfolio-overlay">
                    <span class="portfolio-visit">View project</span>
                  </div>
                </div>
                <div class="portfolio-info">
                  <span class="portfolio-cat">Artificial Intelligence</span>
                  <h3>AFAC26 — Trilingual site, AI agent & payment solution</h3>
                  <p>International conference of African football agents</p>
                </div>
              </a>
            </article>

            <article class="portfolio-card reveal reveal-delay-2">
              <a href="https://www.alexis-mohamed.com" target="_blank" rel="noopener noreferrer" class="portfolio-card-link">
                <div class="portfolio-img-wrap">
                  <img src="/homeMohamed.jpg" alt="Presidential campaign Alexis Mohamed" loading="lazy" />
                  <div class="portfolio-overlay">
                    <span class="portfolio-visit">View project</span>
                  </div>
                </div>
                <div class="portfolio-info">
                  <span class="portfolio-cat">360° Communication</span>
                  <h3>2026 Presidential Campaign — Alexis Mohamed (Djibouti)</h3>
                  <p>Digital strategy and institutional communication</p>
                </div>
              </a>
            </article>

            <article class="portfolio-card reveal reveal-delay-3">
              <a href="https://www.centrachat.africa" target="_blank" rel="noopener noreferrer" class="portfolio-card-link">
                <div class="portfolio-img-wrap">
                  <img src="/centrachat_home.webp" alt="Centrachat Africa — Pan-African purchasing center" loading="lazy" />
                  <div class="portfolio-overlay">
                    <span class="portfolio-visit">View project</span>
                  </div>
                </div>
                <div class="portfolio-info">
                  <span class="portfolio-cat">Digital</span>
                  <h3>Centrachat Africa — 1st pan-African purchasing center</h3>
                  <p>Premium B2B platform, Yaoundé, Cameroon</p>
                </div>
              </a>
            </article>
          </div>

          <div class="portfolio-cta reveal">
            <a href="/portfolio" class="btn-outline">
              View all our projects
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- ===== FINAL CTA ===== -->
      <section class="cta-section">
        <div class="container">
          <div class="cta-inner reveal">
            <span class="label">Ready to start?</span>
            <h2>LET'S TALK ABOUT<br /><span class="gold-text">YOUR PROJECT.</span></h2>
            <p>Whether you need a communication strategy, an AI agent or a premium digital platform, our team is ready to support you.</p>
            <div class="cta-actions">
              <a href="/contact" class="btn-gold">
                Contact us
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
              <a href="https://wa.me/33625523859" target="_blank" rel="noopener noreferrer" class="btn-outline">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-3.825 3.113-6.937 6.937-6.937 1.856.001 3.598.723 4.907 2.034 1.31 1.311 2.031 3.054 2.03 4.908-.001 3.825-3.113 6.938-6.937 6.938z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <Footer />

    <!-- WhatsApp floating button -->
    <a href="https://wa.me/33625523859" class="whatsapp-btn" target="_blank" rel="noopener noreferrer" aria-label="Contact us on WhatsApp">
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-3.825 3.113-6.937 6.937-6.937 1.856.001 3.598.723 4.907 2.034 1.31 1.311 2.031 3.054 2.03 4.908-.001 3.825-3.113 6.938-6.937 6.938z"/>
      </svg>
    </a>
  </div>
</Layout>

<style>
  /* ===== SPLASH ===== */
  .splash {
    position: fixed;
    inset: 0;
    background: var(--black);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }
  .splash.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .splash-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .splash-logo img {
    height: 50px;
    width: auto;
    opacity: 0;
    animation: fadeIn 0.5s ease 0.2s forwards;
  }
  .splash-text {
    display: flex;
    gap: 0.6rem;
    align-items: center;
  }
  .splash-word {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: 0.15em;
    color: var(--white);
    opacity: 0;
    transform: translateY(20px);
    animation: wordReveal 0.6s ease forwards;
  }
  .splash-word[data-word="ONE"] { animation-delay: 0.3s; }
  .splash-word[data-word="NATION"] { animation-delay: 0.5s; }
  .splash-word[data-word="AGENCY"] { animation-delay: 0.7s; color: var(--gold); }
  .splash-tagline {
    font-family: var(--font-body);
    font-size: 0.9rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    text-transform: uppercase;
    opacity: 0;
    animation: fadeIn 0.5s ease 1s forwards;
  }
  .splash-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 3px;
    background: var(--gold);
    width: 0;
    animation: barFill 1.2s ease 0.5s forwards;
  }
  @keyframes wordReveal {
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes barFill {
    to { width: 100%; }
  }
  @keyframes fadeIn {
    to { opacity: 1; }
  }

  /* ===== SITE WRAPPER ===== */
  .site-wrapper {
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .site-wrapper.visible {
    opacity: 1;
  }

  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10,10,10,0.85) 0%, rgba(10,10,10,0.5) 50%, rgba(10,10,10,0.7) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 8rem;
  }
  .hero-badge {
    margin-bottom: 1.5rem;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 6rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--white);
    margin-bottom: 1.5rem;
  }
  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--text-muted);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 1;
  }
  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  .scroll-indicator span {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    color: var(--gold);
    text-transform: uppercase;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.1); }
  }

  /* ===== STATS ===== */
  .stats-bar {
    padding: 3rem 0;
    background: var(--anthracite);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .stats-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }
  .stat-item {
    flex: 1;
    text-align: center;
    padding: 1rem 2rem;
  }
  .stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .stat-divider {
    width: 1px;
    height: 50px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* ===== PILLARS ===== */
  .pillars {
    padding: var(--section-padding) 0;
  }
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1rem;
  }
  .section-intro {
    max-width: 600px;
    margin: 0 auto;
    color: var(--text-muted);
    line-height: 1.7;
  }
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .pillar-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2.5rem 2rem;
    position: relative;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .pillar-card:hover {
    border-color: var(--gold);
    transform: translateY(-4px);
  }
  .pillar-card--featured {
    border-color: var(--gold);
    background: linear-gradient(135deg, var(--card-bg) 0%, rgba(201,168,76,0.05) 100%);
  }
  .pillar-icon {
    color: var(--gold);
    margin-bottom: 1.5rem;
  }
  .pillar-num {
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: var(--gold);
    opacity: 0.6;
    display: block;
    margin-bottom: 0.75rem;
  }
  .pillar-card h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .pillar-card p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
  .pillar-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--gold);
    font-size: 0.85rem;

---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/Section.astro';

const metaDescription = "Build strong relationships with the media through our press relations services. Bespoke strategies, high-impact press releases and crisis communication to maximise your media coverage.";
import { Image } from 'astro:assets';
import imgBrainstorm from '../../assets/brainstorm.jpg';
import imgCommunicationCrise from '../../assets/communication-crise.jpg';
---


<Layout
	title="Press Relations and Media Relations | One Nation"
	description={metaDescription}
	lang="en"
	canonical="/en/press-relations"
	ogImage="/images/relations-presse-banner.jpg"
>
	<Header lang="en" />
	<main id="main-content">
		<section class="hero">
			<div class="hero-content">
				<h1>Press Relations & Media Relations</h1>
				<p>Maximise your media coverage and strengthen your credibility through strategic press relations</p>
				<a href="/en/contact" class="cta-button">Discuss your project</a>
			</div>
		</section>

		<Section id="press-services" title="Our Press Relations services">
			<div class="services-grid">
				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="3"></circle>
							<path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
						</svg>
					</div>
					<h3>Press Relations Strategy</h3>
					<p>Development of bespoke PR strategies aligned with your communication objectives and your institutional positioning.</p>
				</div>

				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
							<polyline points="14 2 14 8 20 8"></polyline>
							<line x1="16" y1="13" x2="8" y2="13"></line>
							<line x1="16" y1="17" x2="8" y2="17"></line>
							<polyline points="10 9 9 9 8 9"></polyline>
						</svg>
					</div>
					<h3>Press Releases</h3>
					<p>Writing and distribution of high-impact press releases that capture journalists' attention and generate media coverage.</p>
				</div>

				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
							<circle cx="9" cy="7" r="4"></circle>
							<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
							<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
						</svg>
					</div>
					<h3>Media Relations</h3>
					<p>Building and maintaining strong relationships with the key journalists and influencers in your sector to maximise your media opportunities.</p>
				</div>

				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
							<line x1="16" y1="2" x2="16" y2="6"></line>
							<line x1="8" y1="2" x2="8" y2="6"></line>
							<line x1="3" y1="10" x2="21" y2="10"></line>
						</svg>
					</div>
					<h3>Press Events</h3>
					<p>Organisation and management of press conferences, press trips and other media events that generate meaningful coverage.</p>
				</div>

				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"></polygon>
							<line x1="12" y1="8" x2="12" y2="12"></line>
							<line x1="12" y1="16" x2="12.01" y2="16"></line>
						</svg>
					</div>
					<h3>Crisis Communication</h3>
					<p>Preparation and implementation of crisis communication strategies to protect your reputation in sensitive situations.</p>
				</div>

				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
							<path d="M22 12A10 10 0 0 0 12 2v10z"></path>
						</svg>
					</div>
					<h3>Media Monitoring & Analysis</h3>
					<p>Monitoring and analysis of your media coverage with detailed reports on the tone, reach and impact of your PR activity.</p>
				</div>
			</div>
		</Section>

		<section class="benefits">
			<div class="container">
				<h2>The benefits of Press Relations</h2>
				<div class="benefits-grid">
					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
								<polyline points="22 4 12 14.01 9 11.01"></polyline>
							</svg>
						</div>
						<h3>Enhanced credibility</h3>
						<p>Coverage from independent third-party sources brings a legitimacy and credibility that advertising cannot match.</p>
					</div>

					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10"></circle>
								<line x1="2" y1="12" x2="22" y2="12"></line>
								<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
							</svg>
						</div>
						<h3>Extended reach</h3>
						<p>Reach a wider and more diverse audience by having your message carried by established and respected media outlets.</p>
					</div>

					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<line x1="12" y1="1" x2="12" y2="23"></line>
								<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
							</svg>
						</div>
						<h3>Cost & efficiency</h3>
						<p>Achieve significant media exposure for an investment that is often lower than that of traditional advertising.</p>
					</div>

					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
								<polyline points="14 2 14 8 20 8"></polyline>
								<line x1="16" y1="13" x2="8" y2="13"></line>
								<line x1="16" y1="17" x2="8" y2="17"></line>
								<polyline points="10 9 9 9 8 9"></polyline>
							</svg>
						</div>
						<h3>Thought leadership</h3>
						<p>Establish yourself as an authority in your field through in-depth features, interviews and opinion pieces.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="process">
			<div class="container">
				<h2>Our approach to Press Relations</h2>
				<div class="process-steps">
					<div class="process-step">
						<div class="step-number">01</div>
						<div class="step-content">
							<h3>Analysis & strategy</h3>
							<p>We begin by understanding your organisation, your objectives and your sector in order to develop a bespoke PR strategy and identify the relevant target media.</p>
						</div>
					</div>

					<div class="process-step">
						<div class="step-number">02</div>
						<div class="step-content">
							<h3>Content creation</h3>
							<p>We develop compelling media angles and write press releases, press kits and other content that capture journalists' attention.</p>
						</div>
					</div>

					<div class="process-step">
						<div class="step-number">03</div>
						<div class="step-content">
							<h3>Media relations</h3>
							<p>We activate our network of media contacts, pitch your story in a personalised way and facilitate interviews and media opportunities.</p>
						</div>
					</div>

					<div class="process-step">
						<div class="step-number">04</div>
						<div class="step-content">
							<h3>Follow-up & amplification</h3>
							<p>We follow up rigorously with the media, make the most of every opportunity and amplify the coverage obtained across your digital channels.</p>
						</div>
					</div>

					<div class="process-step">
						<div class="step-number">05</div>
						<div class="step-content">
							<h3>Measurement & analysis</h3>
							<p>We measure the impact of your PR activity, analyse the coverage obtained and adjust the strategy to optimise future results.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="case-studies">
			<div class="container">
				<h2>Our Press Relations successes</h2>
				<div class="case-studies-grid">
					<div class="case-study">
						<Image src={imgBrainstorm} alt="Press relations campaign" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" decoding="async" />
						<div class="case-study-content">
							<h3>Institutional launch</h3>
							<p>Press relations strategy for the launch of a new government initiative in the field of education.</p>
							<div class="case-results">
								<div class="result">
									<span class="result-number">+120</span>
									<span class="result-label">Media Placements</span>
								</div>
								<div class="result">
									<span class="result-number">15M</span>
									<span class="result-label">Audience Reached</span>
								</div>
							</div>
						</div>
					</div>

					<div class="case-study">
						<Image src={imgCommunicationCrise} alt="Crisis communication" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" decoding="async" />
						<div class="case-study-content">
							<h3>Managing a media crisis</h3>
							<p>Swift and strategic intervention for a company facing a major reputational crisis.</p>
							<div class="case-results">
								<div class="result">
									<span class="result-number">-85%</span>
									<span class="result-label">Negative Coverage</span>
								</div>
								<div class="result">
									<span class="result-number">+60%</span>
									<span class="result-label">Positive Tone</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="media-relations">
			<div class="container">
				<h2>Our media network</h2>
				<p class="intro-text">At One Nation, we have built strong relationships with a wide range of national and international media, spanning different sectors and specialisms.</p>

				<div class="media-categories">
					<div class="media-category">
						<h3>General Press</h3>
						<ul>
							<li>National dailies</li>
							<li>News magazines</li>
							<li>Regional media</li>
							<li>Press agencies</li>
						</ul>
					</div>

					<div class="media-category">
						<h3>Specialist Media</h3>
						<ul>
							<li>Business and financial press</li>
							<li>Sector-specific media</li>
							<li>Trade publications</li>
							<li>Themed magazines</li>
						</ul>
					</div>

					<div class="media-category">
						<h3>Broadcast Media</h3>
						<ul>
							<li>Television channels</li>
							<li>Radio stations</li>
							<li>Podcast platforms</li>
							<li>YouTube channels</li>
						</ul>
					</div>

					<div class="media-category">
						<h3>Digital Media</h3>
						<ul>
							<li>Online news sites</li>
							<li>Influential blogs</li>
							<li>Social media</li>
							<li>Specialist newsletters</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<section class="faq">
			<div class="container">
				<h2>Frequently asked questions</h2>
				<div class="faq-list">
					<details class="faq-item">
						<summary>How do you measure the effectiveness of press relations?</summary>
						<div class="faq-answer">
							<p>The effectiveness of press relations is measured through several key indicators: the number of media placements (articles, features, mentions), the quality and prestige of the outlets covering you, the tone of the coverage (positive, neutral, negative), the potential audience reached, and the advertising value equivalent. We also use more qualitative indicators, such as how faithfully your key messages are picked up, the presence of quotes or interviews, and the impact on your profile and reputation. At One Nation, we provide detailed reports that analyse these different dimensions and connect them to your business objectives.</p>
						</div>
					</details>

					<details class="faq-item">
						<summary>What is the difference between press relations and advertising?</summary>
						<div class="faq-answer">
							<p>The main difference lies in control and credibility. Advertising gives you complete control over the message, the format and the timing, but it is clearly identified as paid content. Press relations, by contrast, involve convincing independent journalists to cover your news, which brings markedly greater credibility and legitimacy with the public. Press relations are generally more economical than advertising in terms of cost per contact, but they require more time and offer fewer guarantees. The ideal approach is often to combine the two within an integrated communication strategy.</p>
						</div>
					</details>

					<details class="faq-item">
						<summary>How do you handle a media crisis effectively?</summary>
						<div class="faq-answer">
							<p>Handling a media crisis effectively rests on several key principles: responsiveness (replying quickly but not hastily), transparency (being honest without necessarily disclosing everything), consistency (aligning all spokespeople on the same messages), and empathy (showing that you understand people's concerns). It is essential to have prepared a crisis communication plan in advance, with scenarios, key messages and a clear chain of decision-making. During the crisis, communication must be centralised, the media and social networks monitored continuously, and your strategy adapted as the situation evolves. After the crisis, a thorough review makes it possible to draw lessons and strengthen your future preparedness.</p>
						</div>
					</details>

					<details class="faq-item">
						<summary>How often should we communicate with the press?</summary>
						<div class="faq-answer">
							<p>The ideal frequency depends on several factors: the size and nature of your organisation, the news cycle in your sector, and above all the relevance of what you have to say. A qualitative rather than quantitative approach is preferable: it is better to communicate less often but with content that is genuinely of interest to journalists. For a mid-sized company, four to six substantial press releases a year may be sufficient, complemented by more targeted activity (opinion pieces, exclusive interviews, and so on). The essential point is to maintain regular relationships with the key journalists in your sector, even outside periods of major announcements.</p>
						</div>
					</details>
				</div>
			</div>
		</section>

		<section class="cta-section">
			<div class="container">
				<h2>Ready to strengthen your media presence?</h2>
				<p>Get in touch today to discuss your press relations needs and find out how we can help you maximise your media coverage.</p>
				<div class="cta-buttons">
					<a href="/en/contact" class="primary-button">Request a quote</a>
					<a href="/en/services" class="secondary-button">Explore our services</a>
				</div>
			</div>
		</section>
	</main>
	<Footer lang="en" />
</Layout>

<style>
	.hero {
		height: 80vh;
		min-height: 600px;
		background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('/relationsPresse.jpg') center/cover no-repeat;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		margin-top: 72px;
	}

	.hero-content {
		max-width: 800px;
		padding: 0 2rem;
	}

	.hero h1 {
		font-size: 3.5rem;
		margin-bottom: 1.5rem;
		line-height: 1.2;
	}

	.hero p {
		font-size: 1.5rem;
		margin-bottom: 2rem;
		opacity: 0.9;
	}

	.cta-button {
		display: inline-block;
		background: var(--color-accent);
		color: var(--color-background);
		padding: 1rem 2rem;
		border-radius: 50px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
	}

	.cta-button:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.service-card {
		background: rgba(255, 255, 255, 0.05);
		padding: 2.5rem 2rem;
		border-radius: 12px;
		transition: transform 0.3s ease;
		text-align: center;
		height: 100%;
	}

	.service-card:hover {
		transform: translateY(-10px);
		background: rgba(255, 255, 255, 0.1);
	}

	.service-icon {
		color: var(--color-accent);
		margin-bottom: 1.5rem;
	}

	.service-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.benefits {
		padding: 8rem 0;
		background: rgba(255, 255, 255, 0.02);
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.benefits h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.benefits-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 3rem;
	}

	.benefit-card {
		text-align: center;
		padding: 2.5rem 2rem;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 12px;
		transition: transform 0.3s ease;
		height: 100%;
	}

	.benefit-card:hover {
		transform: translateY(-10px);
		background: rgba(255, 255, 255, 0.1);
	}

	.benefit-icon {
		color: var(--color-accent);
		margin-bottom: 1.5rem;
	}

	.benefit-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.process {
		padding: 8rem 0;
	}

	.process h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.process-steps {
		max-width: 800px;
		margin: 0 auto;
	}

	.process-step {
		display: flex;
		gap: 2rem;
		margin-bottom: 3rem;
		position: relative;
	}

	.process-step:not(:last-child)::after {
		content: '';
		position: absolute;
		top: 3rem;
		left: 1.5rem;
		width: 2px;
		height: calc(100% + 3rem);
		background: rgba(255, 255, 255, 0.1);
		z-index: -1;
	}

	.step-number {
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--color-accent);
		flex-shrink: 0;
		width: 3rem;
		text-align: center;
	}

	.step-content h3 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.case-studies {
		padding: 8rem 0;
		background: rgba(255, 255, 255, 0.02);
	}

	.case-studies h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.case-studies-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 3rem;
	}

	.case-study {
		background: rgba(255, 255, 255, 0.05);
		border-radius: 12px;
		overflow: hidden;
		transition: transform 0.3s ease;
	}

	.case-study:hover {
		transform: translateY(-10px);
	}

	.case-study img {
		width: 100%;
		height: 250px;
		object-fit: cover;
	}

	.case-study-content {
		padding: 2rem;
	}

	.case-study h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.case-results {
		display: flex;
		justify-content: space-around;
		margin: 1.5rem 0;
	}

	.result {
		text-align: center;
	}

	.result-number {
		display: block;
		font-size: 1.8rem;
		font-weight: 700;
		color: var(--color-accent);
	}

	.result-label {
		font-size: 0.9rem;
		opacity: 0.8;
	}

	.media-relations {
		padding: 8rem 0;
	}

	.media-relations h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 1.5rem;
	}

	.intro-text {
		text-align: center;
		max-width: 800px;
		margin: 0 auto 4rem;
		font-size: 1.2rem;

---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/Section.astro';

const metaDescription = "Discover our communication expertise for the African market. Bespoke solutions, local knowledge and a pan-African network to strengthen your presence in Africa.";
import { Image } from 'astro:assets';
import imgKilimandjaro from '../../assets/kilimandjaro.jpg';
import imgNomadeoAfricaHome from '../../assets/nomadeo-africa-home.jpg';
import imgCampagneInstitutionnelleAfrique from '../../assets/campagne-institutionnelle-afrique.jpg';
import imgEquipeAfrique from '../../assets/equipe_Afrique.jpg';
import imgWfotchine from '../../assets/wfotchine.jpg';
---


<Layout
	title="Strategic communication consultancy for Africa | One Nation"
	description={metaDescription}
	ogImage="/images/afrique-banner.jpg"
	lang="en"
	canonical="/en/africa"
>
	<Header lang="en" />
	<main id="main-content">
		<section class="hero">
			<div class="hero-content">
				<h1>Your communication partner in Africa</h1>
				<p>Local expertise, global vision and bespoke solutions for African markets</p>
				<a href="/en/contact" class="cta-button">Discuss your project</a>
			</div>
		</section>

		<Section id="africa-expertise" title="Our expertise in Africa">
			<div class="expertise-content">
				<div class="expertise-text">
					<p class="intro-text">With our agency based in Yaoundé and our pan-African network, One Nation has a deep understanding of African markets and of their cultural, economic and media specificities.</p>

					<div class="expertise-points">
						<div class="expertise-point">
							<div class="point-icon">
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
									<circle cx="12" cy="10" r="3"></circle>
								</svg>
							</div>
							<div class="point-content">
								<h3>Local presence</h3>
								<p>Our office in Yaoundé places us at the heart of the action and allows us to maintain close relationships with local stakeholders.</p>
							</div>
						</div>

						<div class="expertise-point">
							<div class="point-icon">
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"></circle>
									<line x1="2" y1="12" x2="22" y2="12"></line>
									<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
								</svg>
							</div>
							<div class="point-content">
								<h3>Pan-African network</h3>
								<p>Our network of partners spans the entire continent, enabling us to operate effectively across different countries and regions.</p>
							</div>
						</div>

						<div class="expertise-point">
							<div class="point-icon">
								<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
									<circle cx="9" cy="7" r="4"></circle>
									<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
									<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
								</svg>
							</div>
							<div class="point-content">
								<h3>Multicultural team</h3>
								<p>Our consultants come from a range of African countries, bringing a wealth of perspectives and a nuanced understanding of local contexts.</p>
							</div>
						</div>
					</div>
				</div>

				<div class="expertise-map">
					<Image src={imgKilimandjaro} alt="Kilimanjaro" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" decoding="async" />
				</div>
			</div>
		</Section>

		<section class="services-africa">
			<div class="container">
				<h2>Our services tailored to the African market</h2>
				<div class="services-grid">
					<div class="service-card">
						<div class="service-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"></path>
								<line x1="16" y1="8" x2="2" y2="22"></line>
								<line x1="17.5" y1="15" x2="9" y2="15"></line>
							</svg>
						</div>
						<h3>Tailored branding</h3>
						<p>Creating brand identities that resonate with African values and aspirations while retaining international reach.</p>
					</div>

					<div class="service-card">
						<div class="service-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10"></circle>
								<path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
								<line x1="9" y1="9" x2="9.01" y2="9"></line>
								<line x1="15" y1="9" x2="15.01" y2="9"></line>
							</svg>
						</div>
						<h3>Institutional communication</h3>
						<p>Communication strategies designed for African institutions, respecting local protocols and cultural sensitivities.</p>
					</div>

					<div class="service-card">
						<div class="service-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
								<line x1="8" y1="21" x2="16" y2="21"></line>
								<line x1="12" y1="17" x2="12" y2="21"></line>
							</svg>
						</div>
						<h3>Adapted digital</h3>
						<p>Digital solutions that account for African technological realities: mobile access, variable connectivity and specific usage preferences.</p>
					</div>

					<div class="service-card">
						<div class="service-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
								<circle cx="9" cy="7" r="4"></circle>
								<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
								<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
							</svg>
						</div>
						<h3>Local public relations</h3>
						<p>Managing relations with African media and developing influence strategies suited to local media ecosystems.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="case-studies">
			<div class="container">
				<h2>Our work in Africa</h2>
				<div class="case-studies-grid">
					<div class="case-study">
						<Image src={imgNomadeoAfricaHome} alt="Nomadéo Africa" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" decoding="async" />
						<div class="case-study-content">
							<h3>Nomadéo Africa</h3>
							<p>Development of the digital strategy and creation of the website for this office furniture specialist based in Cameroon.</p>
							<a href="https://nomadeo.africa/" target="_blank" rel="noopener noreferrer" class="read-more">View the project</a>
						</div>
					</div>

					<div class="case-study">
						<Image src={imgCampagneInstitutionnelleAfrique} alt="Institutional campaign" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" decoding="async" />
						<div class="case-study-content">
							<h3>Pan-African institutional campaign</h3>
							<p>Design and rollout of a communication campaign for an international organisation operating across several African countries.</p>
							<a href="/en/portfolio" class="read-more">View the case study</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="africa-approach">
			<div class="container">
				<div class="approach-content">
					<div class="approach-text">
						<h2>Our distinctive approach to Africa</h2>
						<p class="approach-intro">At One Nation, we understand that Africa is not a homogeneous market but a continent rich in cultural, linguistic and economic diversity.</p>

						<div class="approach-points">
							<div class="approach-point">
								<h3>Contextualisation</h3>
								<p>We adapt every strategy to the specific context of the country or region targeted, taking local realities into account.</p>
							</div>

							<div class="approach-point">
								<h3>Frugal innovation</h3>
								<p>We develop creative solutions that maximise impact while accounting for budgetary and logistical constraints.</p>
							</div>

							<div class="approach-point">
								<h3>Skills transfer</h3>
								<p>We train local teams to ensure the longevity of projects and to contribute to the development of African talent.</p>
							</div>
						</div>
					</div>

					<div class="approach-image">
						<Image src={imgEquipeAfrique} alt="Team working in Africa" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" decoding="async" />
					</div>
				</div>
			</div>
		</section>

		<section class="testimonials">
			<div class="container">
				<h2>Testimonials from our African clients</h2>
				<div class="testimonial-slider">
					<div class="testimonial">
						<div class="testimonial-content">
							<p>"One Nation fully grasped the specifics of the Cameroonian market and adapted its strategy accordingly. Their approach considerably strengthened our visibility and our credibility."</p>
							<div class="testimonial-author">
								<Image src={imgWfotchine} alt="William Fotchine" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" decoding="async" />
								<div class="author-info">
									<h4>William Fotchine</h4>
									<p>CEO, Nomadéo Africa</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="cta-section">
			<div class="container">
				<h2>Grow your presence in Africa</h2>
				<p>Whether you are an African institution looking to strengthen your communication or an international organisation seeking to establish itself on the continent, our expertise is at your service.</p>
				<div class="cta-buttons">
					<a href="/en/contact" class="primary-button">Contact us</a>
					<a href="/en/services" class="secondary-button">Discover our services</a>
				</div>
			</div>
		</section>
	</main>
	<Footer lang="en" />
</Layout>

<style>
	.hero {
		height: 80vh;
		min-height: 600px;
		background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('/afrique.jpg') center/cover no-repeat;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		margin-top: 72px;
	}

	.hero-content {
		max-width: 800px;
		padding: 0 2rem;
	}

	.hero h1 {
		font-size: 3.5rem;
		margin-bottom: 1.5rem;
		line-height: 1.2;
	}

	.hero p {
		font-size: 1.5rem;
		margin-bottom: 2rem;
		opacity: 0.9;
	}

	.cta-button {
		display: inline-block;
		background: var(--color-accent);
		color: var(--color-background);
		padding: 1rem 2rem;
		border-radius: 50px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
	}

	.cta-button:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}

	.expertise-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.intro-text {
		font-size: 1.2rem;
		line-height: 1.8;
		margin-bottom: 3rem;
	}

	.expertise-points {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.expertise-point {
		display: flex;
		gap: 1.5rem;
	}

	.point-icon {
		color: var(--color-accent);
		flex-shrink: 0;
	}

	.point-content h3 {
		font-size: 1.3rem;
		margin-bottom: 0.5rem;
	}

	.expertise-map img {
		width: 100%;
		border-radius: 12px;
		box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
	}

	.services-africa {
		padding: 8rem 0;
		background: linear-gradient(to right, rgba(72, 71, 68, 0.8), rgba(72, 71, 68, 0.9)), url('/paysageAfrique.jpg') center/cover no-repeat;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.services-africa h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
	}

	.service-card {
		background: rgba(255, 255, 255, 0.05);
		padding: 2.5rem 2rem;
		border-radius: 12px;
		transition: transform 0.3s ease;
		text-align: center;
	}

	.service-card:hover {
		transform: translateY(-10px);
		background: rgba(255, 255, 255, 0.1);
	}

	.service-icon {
		color: var(--color-accent);
		margin-bottom: 1.5rem;
	}

	.service-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.case-studies {
		padding: 8rem 0;
	}

	.case-studies h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.case-studies-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: 3rem;
	}

	.case-study {
		background: rgba(255, 255, 255, 0.05);
		border-radius: 12px;
		overflow: hidden;
		transition: transform 0.3s ease;
	}

	.case-study:hover {
		transform: translateY(-10px);
	}

	.case-study img {
		width: 100%;
		height: 250px;
		object-fit: cover;
	}

	.case-study-content {
		padding: 2rem;
	}

	.case-study h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.read-more {
		display: inline-block;
		margin-top: 1rem;
		color: var(--color-accent);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.read-more:hover {
		color: var(--color-white);
	}

	.africa-approach {
		padding: 8rem 0;
		background: rgba(255, 255, 255, 0.02);
	}

	.approach-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.approach-text h2 {
		font-size: 2.5rem;
		margin-bottom: 1.5rem;
	}

	.approach-intro {
		font-size: 1.2rem;
		line-height: 1.8;
		margin-bottom: 3rem;
	}

	.approach-points {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.approach-point h3 {
		font-size: 1.3rem;
		color: var(--color-accent);
		margin-bottom: 0.5rem;
	}

	.approach-image img {
		width: 100%;
		border-radius: 12px;
		box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
	}

	.testimonials {
		padding: 8rem 0;
		background: linear-gradient(rgba(72, 71, 68, 0.9), rgba(72, 71, 68, 0.9)), url('/fondTestimony.jpg') center/cover no-repeat;
	}

	.testimonials h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.testimonial {
		max-width: 800px;
		margin: 0 auto;
		background: rgba(255, 255, 255, 0.05);
		padding: 3rem;
		border-radius: 12px;
	}

	.testimonial-content p {
		font-size: 1.3rem;
		font-style: italic;
		line-height: 1.8;
		margin-bottom: 2rem;
	}

	.testimonial-author {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.testimonial-author img {
		width: 70px;
		height: 70px;
		border-radius: 50%;
		object-fit: cover;
	}

	.author-info h4 {
		font-size: 1.2rem;
		margin: 0 0 0.3rem 0;
	}

	.author-info p {
		margin: 0;
		opacity: 0.8;
	}

	.cta-section {
		padding: 6rem 0;
		text-align: center;
	}

	.cta-section h2 {
		font-size: 2.5rem;
		margin-bottom: 1.5rem;
	}

	.cta-section p {
		font-size: 1.2rem;
		max-width: 800px;
		margin: 0 auto 2.5rem;
		opacity: 0.9;
	}

	.cta-buttons {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.primary-button, .secondary-button {
		padding: 1rem 2rem;
		border-radius: 50px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
	}

	.primary-button {
		background: var(--color-accent);
		color: var(--color-background);
	}

	.secondary-button {
		background: transparent;
		color: var(--color-white);
		border: 2px solid var(--color-accent);
	}

	.primary-button:hover, .secondary-button:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}

	@media (max-width: 992px) {
		.expertise-content, .approach-content {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.expertise-map, .approach-image {
			order: -1;
		}
	}

	@media (max-width: 768px) {
		.hero {
			height: 70vh;
		}

		.hero h1 {
			font-size: 2.5rem;
		}

		.hero p {
			font-size: 1.2rem;
		}

		.services-grid, .case-studies-grid {
			grid-template-columns: 1fr;
		}

		.testimonial {
			padding: 2rem;
		}

		.testimonial-content p {
			font-size: 1.1rem;
		}

		.cta-buttons {
			flex-direction: column;
			align-items: center;
		}
	}
</style>

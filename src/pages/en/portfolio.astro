---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const projects = [
  {
    id: "01",
    title: "Centrachat Africa",
    subtitle: "First pan-African purchasing centre",
    category: "Digital & Strategy",
    country: "CAMEROON",
    description: "Creation of the digital platform for the first pan-African purchasing centre based in Yaoundé. Bilingual site, online membership system, complete brand identity.",
    tags: ["Premium Web", "Strategy", "Branding"],
    image: "/centrachat_tablet.png",
    link: "https://www.centrachat.africa",
    color: "#1a3a5c"
  },
  {
    id: "02",
    title: "PaieCashPlay",
    subtitle: "Digital solutions for sports associations",
    category: "Fintech & Artificial Intelligence",
    country: "FRANCE / AFRICA",
    description: "Design and development of the PaieCashPlay digital ecosystem: digital payments, e-commerce, streaming, AI agent and digitalisation of sports clubs.",
    tags: ["Fintech", "AI Agent", "Mobile App"],
    image: "/paiecashplay_phone.png",
    link: "https://www.paiecashplay.com",
    color: "#1a1a2e"
  },
  {
    id: "03",
    title: "AFAC26 Conference",
    subtitle: "Trilingual site, AI agent & international payment",
    category: "Artificial Intelligence",
    country: "INTERNATIONAL",
    description: "Design and development of the official website for the African Football Agents Conference 2026. Trilingual platform (FR/EN/PT), integrated AI agent, international payment system and accreditation.",
    tags: ["AI Agent", "Trilingual Web", "Payment"],
    image: "/afac26_board.png",
    link: "https://www.afaaconference.com/en",
    color: "#0d1b2a"
  },
  {
    id: "04",
    title: "Alexis Mohamed — Djibouti",
    subtitle: "2026 Presidential campaign",
    category: "360° Communication",
    country: "DJIBOUTI",
    description: "Complete communication strategy for the 2026 presidential campaign of Alexis Mohamed. Visual identity, official website, social media management and press relations.",
    tags: ["Political Communication", "Web", "Social Media"],
    image: "/homeMohamed_laptop.webp",
    imagePosition: "70% center",
    link: "https://www.alexis-mohamed.com",
    color: "#1c3a5e"
  },
  {
    id: "05",
    title: "Dr Serge Ghislain Djorie",
    subtitle: "2025 Presidential campaign — Central African Republic",
    category: "360° Communication",
    country: "CENTRAL AFRICAN REPUBLIC",
    description: "Communication direction for the 2025 presidential campaign in the Central African Republic. Digital strategy, official website, content production and media coordination.",
    tags: ["Political Communication", "Strategy", "Media"],
    image: "/djorie_board.png",
    link: "https://www.djorie2025.cf",
    color: "#1a0a2e"
  },
  {
    id: "06",
    title: "Nomadéo Africa",
    subtitle: "E-commerce website redesign — office furniture",
    category: "Digital",
    country: "CAMEROON",
    description: "Complete redesign of the Nomadéo Africa e-commerce site, leader in office furniture in Cameroon. Premium UX/UI, product catalogue, SEO and payment integration.",
    tags: ["E-commerce", "UX/UI", "SEO"],
    image: "/nomadeo_tablet.png",
    link: "https://www.nomadeoafrica.com",
    color: "#1a2a1a"
  },
  {
    id: "07",
    title: "Coplacam",
    subtitle: "Institutional website redesign — Design & Build",
    category: "Digital",
    country: "CAMEROON",
    description: "Redesign of the institutional website for Coplacam Design & Build, a major player in bespoke interior design in Central Africa. Strengthened visual identity and premium user experience.",
    tags: ["Institutional Web", "Design", "Branding"],
    image: "/coplacam_laptop.webp",
    link: "https://www.coplacam.com",
    color: "#2a1a0a"
  }
];
---
<Layout
  title="Portfolio — One Nation Agency | Strategic & Digital Projects"
  description="Discover the strategic, digital and institutional projects carried out by One Nation Agency in Africa, Europe and the Middle East."
  lang="en"
  canonical="/en/portfolio"
>
  <Header lang="en" />
  <main id="main-content">

    <!-- Hero -->
    <section class="pf-hero">
      <div class="pf-hero__bg"></div>
      <div class="pf-hero__content">
        <span class="pf-hero__label">Our Work</span>
        <h1 class="pf-hero__title">Portfolio</h1>
        <p class="pf-hero__sub">Strategic, digital and institutional projects with high added value</p>
      </div>
      <div class="pf-hero__stats">
        <div class="pf-hero__stat">
          <span class="pf-hero__stat-num">07</span>
          <span class="pf-hero__stat-label">Projects</span>
        </div>
        <div class="pf-hero__stat">
          <span class="pf-hero__stat-num">12+</span>
          <span class="pf-hero__stat-label">Countries</span>
        </div>
        <div class="pf-hero__stat">
          <span class="pf-hero__stat-num">3</span>
          <span class="pf-hero__stat-label">Expertises</span>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="pf-projects">
      {projects.map((project, index) => (
        <article
          class={`pf-item ${index % 2 !== 0 ? 'pf-item--alt' : ''}`}
          style={`--project-color: ${project.color};`}
          data-index={index}
        >
          <div class="pf-item__visual">
            <div class="pf-item__bg" style={`background: ${project.color};`}></div>
            <div class="mockup mockup--photo">
              <img
                src={project.image}
                alt={project.title}
                class="mockup__photo-img"
                loading="lazy"
                style={project.imagePosition ? `object-position: ${project.imagePosition}` : 'object-position: center center'}
              />
            </div>
            <div class="pf-item__num-bg">{project.id}</div>
          </div>

          <!-- Project info -->
          <div class="pf-item__info">
            <div class="pf-item__meta">
              <span class="pf-item__country">{project.country}</span>
              <span class="pf-item__sep">|</span>
              <span class="pf-item__category">{project.category}</span>
            </div>
            <div class="pf-item__num">{project.id}</div>
            <h2 class="pf-item__title">{project.title}</h2>
            <p class="pf-item__subtitle">{project.subtitle}</p>
            <p class="pf-item__desc">{project.description}</p>
            <div class="pf-item__tags">
              {project.tags.map(tag => (
                <span class="pf-item__tag">{tag}</span>
              ))}
            </div>
            {project.link !== '#' ? (
              <a href={project.link} target="_blank" rel="noopener noreferrer" class="pf-item__cta">
                <span>View project</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
              </a>
            ) : (
              <span class="pf-item__cta pf-item__cta--locked">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span>Confidential project</span>
              </span>
            )}
          </div>
        </article>
      ))}
    </section>

    <!-- CTA -->
    <section class="pf-cta">
      <div class="pf-cta__glow"></div>
      <div class="pf-cta__inner">
        <span class="pf-cta__label">Your project</span>
        <h2 class="pf-cta__title">Let's build together<br/>your next success</h2>
        <a href="/en/contact" class="pf-cta__btn">Discuss your project</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
/* ============================================
   VARIABLES
   ============================================ */
:root {
  --gold: #c9a84c;
  --gold-light: #e8c96e;
  --bg: #0a0a0a;
  --bg2: #111;
  --white: #fff;
  --grey: rgba(255,255,255,0.5);
  --border: rgba(255,255,255,0.07);
}

/* ============================================
   HERO
   ============================================ */
.pf-hero {
  position: relative;
  min-height: 45vh;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 9rem 6vw 4rem;
  background: var(--bg);
  overflow: hidden;
  gap: 2rem;
}
.pf-hero__bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 15% 60%, rgba(201,168,76,0.07) 0%, transparent 55%),
    radial-gradient(ellipse at 85% 30%, rgba(201,168,76,0.04) 0%, transparent 45%);
}
.pf-hero__content { position: relative; z-index: 1; }
.pf-hero__label {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 0.35em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1rem;
}
.pf-hero__title {
  font-family: 'Clash Display', 'Montserrat', sans-serif;
  font-size: clamp(3.5rem, 9vw, 8rem);
  font-weight: 700;
  color: var(--white);
  line-height: 0.95;
  letter-spacing: -0.03em;
  margin: 0;
}
.pf-hero__sub {
  font-size: 0.9rem;
  color: var(--grey);
  margin: 1.25rem 0 0;
  max-width: 380px;
  line-height: 1.6;
}
.pf-hero__stats {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 3rem;
  align-items: flex-end;
  padding-bottom: 0.5rem;
  flex-shrink: 0;
}
.pf-hero__stat { text-align: center; }
.pf-hero__stat-num {
  display: block;
  font-family: 'Clash Display', 'Montserrat', sans-serif;
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 700;
  color: var(--gold);
  line-height: 1;
  letter-spacing: -0.02em;
}
.pf-hero__stat-label {
  display: block;
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--grey);
  margin-top: 0.4rem;
}

/* ============================================
   PROJECTS GRID
   ============================================ */
.pf-projects { background: var(--bg); }

.pf-item {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 70vh;
  border-bottom: 1px solid var(--border);
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.pf-item.visible {
  opacity: 1;
  transform: translateY(0);
}
.pf-item--alt {
  direction: rtl;
}
.pf-item--alt > * {
  direction: ltr;
}

/* Visual side */
.pf-item__visual {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  background: #0d0d0d;
}
.pf-item__bg {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.5s ease;
  mix-blend-mode: multiply;
}
.pf-item:hover .pf-item__bg { opacity: 1; }

/* Large decorative number */
.pf-item__num-bg {
  position: absolute;
  bottom: -2rem;
  right: -1rem;
  font-family: 'Clash Display', 'Montserrat', sans-serif;
  font-size: clamp(6rem, 12vw, 14rem);
  font-weight: 700;
  color: rgba(255,255,255,0.18);
  line-height: 1;
  letter-spacing: -0.05em;
  user-select: none;
  pointer-events: none;
  z-index: 5;
  text-shadow: 0 2px 30px rgba(201,168,76,0.6), 0 0 60px rgba(201,168,76,0.3);
}

/* ============================================
   PHOTO MOCKUP (full-bleed realistic photo)
   ============================================ */
.mockup--photo {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.mockup__photo-img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: center;
  transition: transform 0.6s cubic-bezier(0.25,0.46,0.45,0.94);
}
.pf-item:hover .mockup__photo-img { transform: scale(1.04); }

/* ============================================
   PROJECT INFO
   ============================================ */
.pf-item__info {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 4rem 5vw 4rem 4vw;
  background: var(--bg);
  position: relative;
}
.pf-item--alt .pf-item__info { padding: 4rem 4vw 4rem 5vw; }

.pf-item__meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.5rem;
  flex-wrap: wrap;
}
.pf-item__country {
  font-size: 0.65rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 600;
}
.pf-item__sep { color: var(--border); font-size: 0.8rem; }
.pf-item__category {
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--grey);
}

/* Number (info side, decorative) */
.pf-item__num {
  font-family: 'Clash Display', 'Montserrat', sans-serif;
  font-size: clamp(4rem, 8vw, 7rem);
  font-weight: 700;
  color: rgba(255,255,255,0.04);
  line-height: 1;
  letter-spacing: -0.05em;
  margin-bottom: -0.75rem;
  user-select: none;
}

.pf-item__title {
  font-family: 'Clash Display', 'Montserrat', sans-serif;
  font-size: clamp(1.5rem, 2.5vw, 2.2rem);
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
  margin: 0 0 0.6rem;
}
.pf-item__subtitle {
  font-size: 0.9rem;
  color: var(--gold);
  font-style: italic;
  margin: 0 0 1rem;
}
.pf-item__desc {
  font-size: 0.875rem;
  line-height: 1.75;
  color: var(--grey);
  margin: 0 0 1.75rem;
  max-width: 400px;
}
.pf-item__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-bottom: 2rem;
}
.pf-item__tag {
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.45);
  border: 1px solid rgba(255,255,255,0.1);
  padding: 0.3rem 0.75rem;
  border-radius: 100px;
  transition: all 0.3s;
}
.pf-item:hover .pf-item__tag {
  border-color: rgba(201,168,76,0.4);
  color: var(--gold);
}

.pf-item__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--white);
  text-decoration: none;
  padding: 0.9rem 1.75rem;
  border: 1px solid rgba(201,168,76,0.45);
  border-radius: 100px;
  transition: all 0.35s;
  width: fit-content;
  position: relative;
  overflow: hidden;
}
.pf-item__cta::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gold);
  transform: translateX(-100%);
  transition: transform 0.35s cubic-bezier(0.25,0.46,0.45,0.94);
}
.pf-item__cta:hover::before { transform: translateX(0); }
.pf-item__cta span,
.pf-item__cta svg {
  position: relative;
  z-index: 1;
}
.pf-item__cta:hover { color: #000; border-color: var(--gold); }
.pf-item__cta--locked {
  opacity: 0.35;
  cursor: default;
  pointer-events: none;
  font-size: 0.75rem;
}

/* ============================================
   CTA FINAL
   ============================================ */
.pf-cta {
  background: var(--bg);
  padding: 9rem 6vw;
  text-align: center;
  border-top: 1px solid rgba(201,168,76,0.12);
  position: relative;
  overflow: hidden;
}
.pf-cta__glow {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 300px;
  background: radial-gradient(ellipse at center bottom, rgba(201,168,76,0.1) 0%, transparent 70%);
  pointer-events: none;
}
.pf-cta__inner { position: relative; z-index: 1; }
.pf-cta__label {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.5rem;
}
.pf-cta__title {
  font-family: 'Clash Display', 'Montserrat', sans-serif;
  font-size: clamp(2rem, 5vw, 4rem);
  font-weight: 700;
  color: var(--white);
  line-height: 1.15;
  margin: 0 0 3rem;
}
.pf-cta__btn {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #000;
  text-decoration: none;
  padding: 1.2rem 3rem;
  background: var(--gold);
  border-radius: 100px;
  transition: all 0.35s;
}
.pf-cta__btn:hover {
  background: var(--white);
  transform: translateY(-3px);
  box-shadow: 0 16px 50px rgba(201,168,76,0.35);
}

/* ============================================
   RESPONSIVE
   ============================================ */
@media (max-width: 1024px) {
  .pf-item {
    grid-template-columns: 1fr;
    min-height: auto;
    direction: ltr !important;
  }
  .pf-item__visual {
    min-height: 50vw;
  }
  .pf-item__info {
    padding: 3rem 5vw !important;
  }
}
@media (max-width: 768px) {
  .pf-hero {
    flex-direction: column;
    align-items: flex-start;
    gap: 2.5rem;
    padding: 7.5rem 5vw 3rem;
  }
  .pf-hero__stats { gap: 2rem; }
  .pf-item__visual { min-height: 60vw; }
  .pf-item__num { font-size: 3.5rem; }
  .pf-cta { padding: 6rem 5vw; }
}
@media (max-width: 480px) {
  .pf-hero { padding: 6.5rem 5vw 2.5rem; }
  .pf-item__visual { min-height: 65vw; }
}
</style>

<script>
// Scroll reveal animation
const items = document.querySelectorAll('.pf-item');
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      setTimeout(() => {
        entry.target.classList.add('visible');
      }, 100);
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.08 });
items.forEach(item => observer.observe(item));
</script>

---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const projects = [
  {
    id: "01",
    mockup: "laptop",
    title: "Centrachat Africa",
    subtitle: "First pan-African purchasing centre",
    category: "Digital & Strategy",
    country: "CAMEROON",
    description: "Creation of the digital platform for the first pan-African purchasing centre based in Yaoundé. Bilingual site, online membership system, complete brand identity.",
    tags: ["Premium Web", "Strategy", "Branding"],
    image: "/homeCentrachat.webp",
    link: "https://www.centrachat.africa",
    color: "#1a3a5c"
  },
  {
    id: "02",
    mockup: "phone",
    title: "PaieCashPlay",
    subtitle: "Digital solutions for sports associations",
    category: "Fintech & Artificial Intelligence",
    country: "FRANCE / AFRICA",
    description: "Design and development of the PaieCashPlay digital ecosystem: digital payments, e-commerce, streaming, AI agent and digitalisation of sports clubs.",
    tags: ["Fintech", "AI Agent", "Mobile App"],
    image: "/homePaiecashplay.webp",
    link: "https://www.paiecashplay.com",
    color: "#1a1a2e"
  },
  {
    id: "03",
    mockup: "screen",
    title: "AFAC26 Conference",
    subtitle: "Trilingual site, AI agent & international payment",
    category: "Artificial Intelligence",
    country: "INTERNATIONAL",
    description: "Design and development of the official website for the African Football Agents Conference 2026. Trilingual platform (FR/EN/PT), integrated AI agent, international payment system and accreditation.",
    tags: ["AI Agent", "Trilingual Web", "Payment"],
    image: "/Afac26_home.jpg",
    link: "https://www.afaaconference.com/en",
    color: "#0d1b2a"
  },
  {
    id: "04",
    mockup: "laptop",
    title: "Alexis Mohamed — Djibouti",
    subtitle: "2026 Presidential campaign",
    category: "360° Communication",
    country: "DJIBOUTI",
    description: "Complete communication strategy for the 2026 presidential campaign of Alexis Mohamed. Visual identity, official website, social media management and press relations.",
    tags: ["Political Communication", "Web", "Social Media"],
    image: "/homeMohamed.jpg",
    link: "https://www.alexismohamed.dj",
    color: "#1c3a5e"
  },
  {
    id: "05",
    mockup: "screen",
    title: "Dr Serge Ghislain Djorie",
    subtitle: "2025 Presidential campaign — Central African Republic",
    category: "360° Communication",
    country: "CENTRAL AFRICAN REPUBLIC",
    description: "Communication direction for the 2025 presidential campaign in the Central African Republic. Digital strategy, official website, content production and media coordination.",
    tags: ["Political Communication", "Strategy", "Media"],
    image: "/homeDjorie.jpg",
    link: "https://www.djorie2025.cf",
    color: "#1a0a2e"
  },
  {
    id: "06",
    mockup: "laptop",
    title: "Nomadéo Africa",
    subtitle: "E-commerce website redesign — office furniture",
    category: "Digital",
    country: "CAMEROON",
    description: "Complete redesign of the Nomadéo Africa e-commerce site, leader in office furniture in Cameroon. Premium UX/UI, product catalogue, SEO and payment integration.",
    tags: ["E-commerce", "UX/UI", "SEO"],
    image: "/nomadeo africa home.jpg",
    link: "https://www.nomadeoafrica.com",
    color: "#1a2a1a"
  },
  {
    id: "07",
    mockup: "phone",
    title: "Coplacam",
    subtitle: "Institutional website redesign — Design & Build",
    category: "Digital",
    country: "CAMEROON",
    description: "Redesign of the institutional website for Coplacam Design & Build, a major player in bespoke interior design in Central Africa. Strengthened visual identity and premium user experience.",
    tags: ["Institutional Web", "Design", "Branding"],
    image: "/coplacam_home.png",
    link: "https://www.coplacam.com",
    color: "#2a1a0a"
  }
];
---


<Layout title="Portfolio — One Nation Agency | Strategic & Digital Projects" description="Discover the strategic, digital and institutional projects carried out by One Nation Agency in Africa, Europe and the Middle East.">
  <Header lang="en" />

  <main id="main-content">

    <!-- Hero -->
    <section class="pf-hero">
      <div class="pf-hero__bg"></div>
      <div class="pf-hero__content">
        <span class="pf-hero__label">Our Work</span>
        <h1 class="pf-hero__title">Portfolio</h1>
        <p class="pf-hero__sub">Strategic, digital and institutional projects with high added value</p>
      </div>
      <div class="pf-hero__stats">
        <div class="pf-hero__stat">
          <span class="pf-hero__stat-num">07</span>
          <span class="pf-hero__stat-label">Projects</span>
        </div>
        <div class="pf-hero__stat">
          <span class="pf-hero__stat-num">12+</span>
          <span class="pf-hero__stat-label">Countries</span>
        </div>
        <div class="pf-hero__stat">
          <span class="pf-hero__stat-num">3</span>
          <span class="pf-hero__stat-label">Expertises</span>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section class="pf-projects">
      {projects.map((project, index) => (
        <article
          class={`pf-item pf-item--${project.mockup} ${index % 2 !== 0 ? 'pf-item--alt' : ''}`}
          style={`--project-color: ${project.color};`}
          data-index={index}
        >
          <div class="pf-item__visual">
            <div class="pf-item__bg" style={`background: ${project.color};`}></div>

            {project.mockup === 'laptop' && (
              <div class="mockup mockup--laptop">
                <div class="mockup__laptop-body">
                  <div class="mockup__laptop-screen">
                    <div class="mockup__laptop-bar">
                      <span class="mockup__dot mockup__dot--red"></span>
                      <span class="mockup__dot mockup__dot--yellow"></span>
                      <span class="mockup__dot mockup__dot--green"></span>
                    </div>
                    <div class="mockup__screen-content">
                      <img src={project.image} alt={project.title} class="mockup__img" loading="lazy" />
                    </div>
                  </div>
                </div>
                <div class="mockup__laptop-base">
                  <div class="mockup__laptop-hinge"></div>
                </div>
              </div>
            )}

            {project.mockup === 'phone' && (
              <div class="mockup mockup--phone">
                <div class="mockup__phone-body">
                  <div class="mockup__phone-notch"></div>
                  <div class="mockup__phone-screen">
                    <img src={project.image} alt={project.title} class="mockup__img" loading="lazy" />
                  </div>
                  <div class="mockup__phone-home"></div>
                </div>
              </div>
            )}

            {project.mockup === 'screen' && (
              <div class="mockup mockup--screen">
                <div class="mockup__screen-frame">
                  <div class="mockup__screen-bezel">
                    <div class="mockup__screen-content">
                      <img src={project.image} alt={project.title} class="mockup__img" loading="lazy" />
                    </div>
                  </div>
                </div>
                <div class="mockup__screen-stand">
                  <div class="mockup__screen-neck"></div>
                  <div class="mockup__screen-foot"></div>
                </div>
              </div>
            )}

            <div class="pf-item__num-bg">{project.id}</div>
          </div>

          <div class="pf-item__info">
            <div class="pf-item__meta">
              <span class="pf-item__country">{project.country}</span>
              <span class="pf-item__sep">|</span>
              <span class="pf-item__category">{project.category}</span>
            </div>
            <div class="pf-item__num">{project.id}</div>
            <h2 class="pf-item__title">{project.title}</h2>
            <p class="pf-item__subtitle">{project.subtitle}</p>
            <p class="pf-item__desc">{project.description}</p>
            <div class="pf-item__tags">
              {project.tags.map(tag => (
                <span class="pf-item__tag">{tag}</span>
              ))}
            </div>
            {project.link !== '#' ? (
              <a href={project.link} target="_blank" rel="noopener noreferrer" class="pf-item__cta">
                <span>View project</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
              </a>
            ) : (
              <span class="pf-item__cta pf-item__cta--locked">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span>Confidential project</span>
              </span>
            )}
          </div>
        </article>
      ))}
    </section>

    <!-- CTA -->
    <section class="pf-cta">
      <div class="pf-cta__glow"></div>
      <div class="pf-cta__inner">
        <span class="pf-cta__label">Your project</span>
        <h2 class="pf-cta__title">Let's build your next<br/>success together</h2>
        <a href="/contact" class="pf-cta__btn">Discuss your project</a>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
:root {
  --gold: #c9a84c;
  --gold-light: #e8c96e;
  --bg: #0a0a0a;
  --bg2: #111;
  --white: #fff;
  --grey: rgba(255,255,255,0.5);
  --border: rgba(255,255,255,0.07);
}
.pf-hero { position: relative; min-height: 45vh; display: flex; align-items: flex-end; justify-content: space-between; padding: 9rem 6vw 4rem; background: var(--bg); overflow: hidden; gap: 2rem; }
.pf-hero__bg { position: absolute; inset: 0; background: radial-gradient(ellipse at 15% 60%, rgba(201,168,76,0.07) 0%, transparent 55%), radial-gradient(ellipse at 85% 30%, rgba(201,168,76,0.04) 0%, transparent 45%); }
.pf-hero__content { position: relative; z-index: 1; }
.pf-hero__label { display: block; font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
.pf-hero__title { font-family: 'Clash Display', 'Montserrat', sans-serif; font-size: clamp(3.5rem, 9vw, 8rem); font-weight: 700; color: var(--white); line-height: 1; margin: 0 0 1rem; letter-spacing: -0.03em; }
.pf-hero__sub { font-size: 0.95rem; color: var(--grey); max-width: 380px; line-height: 1.6; }
.pf-hero__stats { position: relative; z-index: 1; display: flex; gap: 3rem; align-items: flex-end; flex-shrink: 0; }
.pf-hero__stat { text-align: center; }
.pf-hero__stat-num { display: block; font-family: 'Clash Display', 'Montserrat', sans-serif; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 700; color: var(--gold); line-height: 1; }
.pf-hero__stat-label { display: block; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-top: 0.4rem; }
.pf-projects { background: var(--bg); }
.pf-item { display: grid; grid-template-columns: 55% 45%; min-height: 90vh; border-bottom: 1px solid var(--border); position: relative; overflow: hidden; opacity: 0; transform: translateY(50px); transition: opacity 0.9s cubic-bezier(0.25,0.46,0.45,0.94), transform 0.9s cubic-bezier(0.25,0.46,0.45,0.94); }
.pf-item.visible { opacity: 1; transform: translateY(0); }
.pf-item--alt { grid-template-columns: 45% 55%; direction: rtl; }
.pf-item--alt > * { direction: ltr; }
.pf-item__visual { position: relative; display: flex; align-items: center; justify-content: center; padding: 4rem 3rem; overflow: hidden; }
.pf-item__bg { position: absolute; inset: 0; opacity: 0.15; }
.pf-item__num-bg { position: absolute; bottom: -0.5rem; right: 1rem; font-family: 'Clash Display', 'Montserrat', sans-serif; font-size: clamp(6rem, 12vw, 14rem); font-weight: 900; color: rgba(255,255,255,0.03); line-height: 1; pointer-events: none; user-select: none; }
.pf-item__info { display: flex; flex-direction: column; justify-content: center; padding: 4rem 4rem 4rem 3rem; }
.pf-item--alt .pf-item__info { padding: 4rem 3rem 4rem 4rem; }
.pf-item__meta { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; }
.pf-item__country { font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); font-weight: 600; }
.pf-item__sep { color: rgba(255,255,255,0.2); font-size: 0.7rem; }
.pf-item__category { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.4); }
.pf-item__num { font-family: 'Clash Display', 'Montserrat', sans-serif; font-size: 0.75rem; font-weight: 700; color: rgba(201,168,76,0.3); letter-spacing: 0.2em; margin-bottom: 0.75rem; }
.pf-item__title { font-family: 'Clash Display', 'Montserrat', sans-serif; font-size: clamp(1.6rem, 3vw, 2.8rem); font-weight: 700; color: var(--white); line-height: 1.1; margin-bottom: 0.6rem; letter-spacing: -0.02em; }
.pf-item__subtitle { font-size: 0.9rem; color: var(--gold); font-weight: 500; margin-bottom: 1.5rem; letter-spacing: 0.02em; }
.pf-item__desc { font-size: 0.9rem; color: rgba(255,255,255,0.55); line-height: 1.75; margin-bottom: 2rem; max-width: 440px; }
.pf-item__tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; }
.pf-item__tag { font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.12); padding: 0.3rem 0.8rem; border-radius: 20px; }
.pf-item__cta { display: inline-flex; align-items: center; gap: 0.75rem; background: var(--gold); color: #0a0a0a; font-family: 'Clash Display', 'Montserrat', sans-serif; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.9rem 1.75rem; border-radius: 4px; text-decoration: none; transition: background 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease; }
.pf-item__cta:hover { background: var(--gold-light); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(201,168,76,0.3); }
.pf-item__cta--locked { background: transparent; border: 1px solid rgba(255,255,255,0.1); color: rgba(255,255,255,0.3); cursor: default; font-size: 0.75rem; gap: 0.5rem; }
.pf-item__cta--locked:hover { background: transparent; transform: none; box-shadow: none; }
/* MOCKUP LAPTOP */
.mockup--laptop { width: min(420px, 80%); filter: drop-shadow(0 30px 60px rgba(0,0,0,0.6)); }
.mockup__laptop-body { background: #1a1a1a; border-radius: 10px 10px 0 0; padding: 8px 8px 0; border: 1px solid rgba(255,255,255,0.08); }
.mockup__laptop-screen { background: #0a0a0a; border-radius: 6px 6px 0 0; overflow: hidden; }
.mockup__laptop-bar { display: flex; gap: 5px; padding: 6px 10px; background: #111; }
.mockup__dot { width: 7px; height: 7px; border-radius: 50%; }
.mockup__dot--red { background: #ff5f57; }
.mockup__dot--yellow { background: #febc2e; }
.mockup__dot--green { background: #28c840; }
.mockup__screen-content { aspect-ratio: 16/10; overflow: hidden; }
.mockup__img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
.mockup__laptop-base { background: linear-gradient(to bottom, #222, #1a1a1a); height: 14px; border-radius: 0 0 4px 4px; border: 1px solid rgba(255,255,255,0.06); border-top: none; position: relative; }
.mockup__laptop-hinge { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 60px; height: 6px; background: #333; border-radius: 0 0 3px 3px; }
/* MOCKUP PHONE */
.mockup--phone { width: min(200px, 45%); filter: drop-shadow(0 30px 60px rgba(0,0,0,0.6)); }
.mockup__phone-body { background: #1a1a1a; border-radius: 28px; padding: 10px 8px; border: 1px solid rgba(255,255,255,0.1); position: relative; }
.mockup__phone-notch { width: 60px; height: 16px; background: #0a0a0a; border-radius: 0 0 10px 10px; margin: 0 auto 6px; }
.mockup__phone-screen { border-radius: 4px; overflow: hidden; aspect-ratio: 9/19; }
.mockup__phone-home { width: 40px; height: 4px; background: rgba(255,255,255,0.15); border-radius: 2px; margin: 8px auto 0; }
/* MOCKUP SCREEN */
.mockup--screen { width: min(480px, 85%); filter: drop-shadow(0 30px 60px rgba(0,0,0,0.6)); }
.mockup__screen-frame { background: #1a1a1a; border-radius: 8px; padding: 8px; border: 1px solid rgba(255,255,255,0.08); }
.mockup__screen-bezel { background: #0a0a0a; border-radius: 4px; overflow: hidden; }
.mockup__screen-stand { display: flex; flex-direction: column; align-items: center; }
.mockup__screen-neck { width: 40px; height: 30px; background: linear-gradient(to bottom, #1a1a1a, #222); }
.mockup__screen-foot { width: 120px; height: 8px; background: #222; border-radius: 0 0 4px 4px; }
/* CTA */
.pf-cta { position: relative; padding: 8rem 6vw; background: var(--bg); text-align: center; overflow: hidden; border-top: 1px solid var(--border); }
.pf-cta__glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 600px; height: 300px; background: radial-gradient(ellipse, rgba(201,168,76,0.08) 0%, transparent 70%); pointer-events: none; }
.pf-cta__inner { position: relative; z-index: 1; }
.pf-cta__label { display: block; font-size: 0.7rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.5rem; }
.pf-cta__title { font-family: 'Clash Display', 'Montserrat', sans-serif; font-size: clamp(2rem, 5vw, 4rem); font-weight: 700; color: var(--white); line-height: 1.15; margin-bottom: 3rem; letter-spacing: -0.02em; }
.pf-cta__btn { display: inline-flex; align-items: center; gap: 0.75rem; background: var(--gold); color: #0a0a0a; font-family: 'Clash Display', 'Montserrat', sans-serif; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 1.1rem 2.5rem; border-radius: 4px; text-decoration: none; transition: background 0.3s ease, transform 0.3s ease; }
.pf-cta__btn:hover { background: var(--gold-light); transform: translateY(-2px); }
@media (max-width: 1024px) {
  .pf-item { grid-template-columns: 1fr; min-height: auto; }
  .pf-item--alt { grid-template-columns: 1fr; direction: ltr; }
  .pf-item__visual { min-height: 50vh; padding: 3rem 2rem; }
  .pf-item__info { padding: 3rem 2rem; }
  .pf-item--alt .pf-item__info { padding: 3rem 2rem; }
  .pf-hero { flex-direction: column; align-items: flex-start; padding: 8rem 5vw 3rem; }
}
@media (max-width: 768px) {
  .pf-hero__stats { gap: 2rem; }
  .mockup--laptop { width: 90%; }
  .mockup--screen { width: 95%; }
}
</style>

<script>
const items = document.querySelectorAll('.pf-item');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -80px 0px' });
items.forEach(item => observer.observe(item));
</script>

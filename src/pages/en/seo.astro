---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/Section.astro';

const metaDescription = "Optimise your online visibility with One Nation's SEO services. Tailored strategies, technical optimisation and quality content to improve your search engine rankings.";
import { Image } from 'astro:assets';
import imgApprocheSeo from '../../assets/approcheSeo.jpg';
import imgSeo from '../../assets/seo.jpg';
---


<Layout
	title="SEO for Institutions and Businesses | One Nation"
	description={metaDescription}
	lang="en"
	canonical="/en/seo"
	ogImage="/images/referencement-banner.jpg"
>
	<Header lang="en" />
	<main id="main-content">
		<section class="hero">
			<div class="hero-content">
				<h1>Strategic SEO</h1>
				<p>Improve your online visibility and attract qualified traffic with our tailored SEO strategies</p>
				<a href="/en/contact" class="cta-button">Request a free SEO audit</a>
			</div>
		</section>

		<Section id="seo-approach" title="Our approach to SEO">
			<div class="approach-content">
				<div class="approach-text">
					<p class="intro-text">At One Nation, we see SEO as a cornerstone of your wider digital strategy. Our approach combines technical expertise, strategic content creation and continuous analysis to deliver lasting results.</p>

					<div class="approach-steps">
						<div class="step">
							<div class="step-number">01</div>
							<div class="step-content">
								<h3>Audit & analysis</h3>
								<p>A complete assessment of your current online presence, competitor analysis and identification of growth opportunities.</p>
							</div>
						</div>

						<div class="step">
							<div class="step-number">02</div>
							<div class="step-content">
								<h3>Personalised strategy</h3>
								<p>Developing a tailored SEO strategy aligned with your commercial objectives and your institutional positioning.</p>
							</div>
						</div>

						<div class="step">
							<div class="step-number">03</div>
							<div class="step-content">
								<h3>Technical optimisation</h3>
								<p>Improving your site's technical structure to make indexing and crawling easier for search engines.</p>
							</div>
						</div>

						<div class="step">
							<div class="step-number">04</div>
							<div class="step-content">
								<h3>Strategic content</h3>
								<p>Creating and optimising relevant content that answers the search intent of your target audience.</p>
							</div>
						</div>

						<div class="step">
							<div class="step-number">05</div>
							<div class="step-content">
								<h3>Tracking & optimisation</h3>
								<p>Continuous performance monitoring and strategic adjustments to maintain and improve your rankings.</p>
							</div>
						</div>
					</div>
				</div>

				<div class="approach-image">
					<Image src={imgApprocheSeo} alt="SEO strategy" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" decoding="async" />
				</div>
			</div>
		</Section>

		<section class="seo-services">
			<div class="container">
				<h2>Our SEO services</h2>
				<div class="services-grid">
					<div class="service-card">
						<div class="service-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="11" cy="11" r="8"></circle>
								<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
							</svg>
						</div>
						<h3>On-page SEO</h3>
						<p>Optimising meta tags, content structure, internal linking and user experience to improve your position in search results.</p>
					</div>

					<div class="service-card">
						<div class="service-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
								<path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
							</svg>
						</div>
						<h3>Off-page SEO</h3>
						<p>Developing quality backlink strategies, building relationships with influencers and strengthening your domain authority.</p>
					</div>

					<div class="service-card">
						<div class="service-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
							</svg>
						</div>
						<h3>Technical SEO</h3>
						<p>Optimising loading speed, site structure and schema.org markup, and resolving the technical issues affecting your rankings.</p>
					</div>

					<div class="service-card">
						<div class="service-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
								<polyline points="14 2 14 8 20 8"></polyline>
								<line x1="16" y1="13" x2="8" y2="13"></line>
								<line x1="16" y1="17" x2="8" y2="17"></line>
								<polyline points="10 9 9 9 8 9"></polyline>
							</svg>
						</div>
						<h3>SEO content marketing</h3>
						<p>Creating optimised content that meets your audience's needs while improving your rankings on strategic keywords.</p>
					</div>

					<div class="service-card">
						<div class="service-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
								<line x1="8" y1="21" x2="16" y2="21"></line>
								<line x1="12" y1="17" x2="12" y2="21"></line>
							</svg>
						</div>
						<h3>Local SEO</h3>
						<p>Optimising your local presence so you appear in geolocated searches and on Google Maps essential for institutions with a physical presence.</p>
					</div>

					<div class="service-card">
						<div class="service-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M21.21 15.89A10 10 0 1 1 8 2.83"></path>
								<path d="M22 12A10 10 0 0 0 12 2v10z"></path>
							</svg>
						</div>
						<h3>Analysis & reporting</h3>
						<p>Detailed performance tracking with regular reports and data-driven recommendations for continuous optimisation.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="benefits">
			<div class="container">
				<h2>Why invest in SEO?</h2>
				<div class="benefits-grid">
					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10"></circle>
								<polyline points="12 6 12 12 16 14"></polyline>
							</svg>
						</div>
						<h3>Lasting results</h3>
						<p>Unlike paid advertising, SEO delivers long-term results that continue to improve over time.</p>
					</div>

					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<line x1="12" y1="1" x2="12" y2="23"></line>
								<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
							</svg>
						</div>
						<h3>Cost-effectiveness</h3>
						<p>SEO offers one of the best returns on investment of any digital marketing strategy.</p>
					</div>

					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
								<polyline points="22 4 12 14.01 9 11.01"></polyline>
							</svg>
						</div>
						<h3>Greater credibility</h3>
						<p>Appearing at the top of search results strengthens your credibility and authority in your field.</p>
					</div>

					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
								<circle cx="9" cy="7" r="4"></circle>
								<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
								<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
							</svg>
						</div>
						<h3>Qualified traffic</h3>
						<p>SEO attracts visitors who are actively looking for your services, increasing the likelihood of conversion.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="case-study">
			<div class="container">
				<div class="case-study-content">
					<div class="case-study-text">
						<h2>Case study: improving an institution's search performance</h2>
						<p class="case-intro">See how we helped a government institution increase its organic traffic by 215% in six months.</p>

						<div class="case-details">
							<div class="case-stat">
								<span class="stat-number">+215%</span>
								<span class="stat-label">Organic traffic</span>
							</div>

							<div class="case-stat">
								<span class="stat-number">+180%</span>
								<span class="stat-label">Keyword visibility</span>
							</div>

							<div class="case-stat">
								<span class="stat-number">+75%</span>
								<span class="stat-label">Conversion rate</span>
							</div>
						</div>

						<p class="case-description">Our strategy combined a technical overhaul of the site, optimisation of existing content and the creation of new content targeting strategic keywords. We also implemented a backlink strategy with authoritative sources in the sector.</p>

						<a href="/en/portfolio" class="case-link">Read the full case study</a>
					</div>

					<div class="case-study-image">
						<Image src={imgSeo} alt="Google SEO" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" decoding="async" />
					</div>
				</div>
			</div>
		</section>

		<section class="faq">
			<div class="container">
				<h2>Frequently asked questions about SEO</h2>
				<div class="faq-list">
					<details class="faq-item">
						<summary>How long does it take to see SEO results?</summary>
						<div class="faq-answer">
							<p>SEO is a medium- to long-term strategy. The first results can be visible after three to six months, but the most significant effects generally appear after six to twelve months of sustained effort. It also depends on the level of competition in your sector, the initial state of your site and how ambitious your strategy is.</p>
						</div>
					</details>

					<details class="faq-item">
						<summary>How does SEO fit into our overall communication strategy?</summary>
						<div class="faq-answer">
							<p>SEO is a cornerstone of your digital presence and supports every other communication initiative. It improves the visibility of your content, strengthens your credibility and ensures your message reaches your target audience at the moment they are actively looking for information. At One Nation, we integrate SEO into a holistic communication strategy that aligns all your channels to maximise your impact.</p>
						</div>
					</details>

					<details class="faq-item">
						<summary>What kind of reports and metrics do you provide?</summary>
						<div class="faq-answer">
							<p>We provide detailed monthly reports covering key metrics such as organic traffic, keyword positions, conversion rate, bounce rate and time on site. Our reports are personalised to your specific objectives and include qualitative analysis alongside optimisation recommendations. We use tools such as Google Analytics, Google Search Console and specialist SEO platforms to collect and analyse this data.</p>
						</div>
					</details>

					<details class="faq-item">
						<summary>How do you adapt your SEO approach for institutions?</summary>
						<div class="faq-answer">
							<p>For institutions, our SEO approach places the emphasis on credibility, authority and trust. We focus on optimising for keywords relevant to your mission, creating high-quality content that demonstrates your expertise, and building backlinks from reliable, authoritative sources. We also take into account the considerations specific to institutions, such as regulatory compliance, reputation protection and communicating complex messages in an accessible way.</p>
						</div>
					</details>
				</div>
			</div>
		</section>

		<section class="cta-section">
			<div class="container">
				<h2>Ready to improve your online visibility?</h2>
				<p>Contact us today for a free SEO audit and find out how we can help you reach your search objectives.</p>
				<div class="cta-buttons">
					<a href="/en/contact" class="primary-button">Request a free audit</a>
					<a href="/en/services" class="secondary-button">Explore our services</a>
				</div>
			</div>
		</section>
	</main>
	<Footer lang="en" />
</Layout>

<style>
	.hero {
		height: 80vh;
		min-height: 600px;
		background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('/social_media.jpg') center/cover no-repeat;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		margin-top: 72px;
	}

	.hero-content {
		max-width: 800px;
		padding: 0 2rem;
	}

	.hero h1 {
		font-size: 3.5rem;
		margin-bottom: 1.5rem;
		line-height: 1.2;
	}

	.hero p {
		font-size: 1.5rem;
		margin-bottom: 2rem;
		opacity: 0.9;
	}

	.cta-button {
		display: inline-block;
		background: var(--color-accent);
		color: var(--color-background);
		padding: 1rem 2rem;
		border-radius: 50px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
	}

	.cta-button:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}

	.approach-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.intro-text {
		font-size: 1.2rem;
		line-height: 1.8;
		margin-bottom: 3rem;
	}

	.approach-steps {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.step {
		display: flex;
		gap: 1.5rem;
	}

	.step-number {
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--color-accent);
		opacity: 0.5;
		line-height: 1;
	}

	.step-content h3 {
		font-size: 1.3rem;
		margin-bottom: 0.5rem;
	}

	.approach-image img {
		width: 100%;
		border-radius: 12px;
		box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
	}

	.seo-services {
		padding: 8rem 0;
		background: linear-gradient(to right, rgba(72, 71, 68, 0.8), rgba(72, 71, 68, 0.9)), url('/analyseSeo.jpg') center/cover no-repeat;
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.seo-services h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.service-card {
		background: rgba(255, 255, 255, 0.05);
		padding: 2.5rem 2rem;
		border-radius: 12px;
		transition: transform 0.3s ease;
		text-align: center;
	}

	.service-card:hover {
		transform: translateY(-10px);
		background: rgba(255, 255, 255, 0.1);
	}

	.service-icon {
		color: var(--color-accent);
		margin-bottom: 1.5rem;
	}

	.service-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.benefits {
		padding: 8rem 0;
	}

	.benefits h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.benefits-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 3rem;
	}

	.benefit-card {
		text-align: center;
		padding: 2rem;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 12px;
		transition: transform 0.3s ease;
	}

	.benefit-card:hover {
		transform: translateY(-10px);
		background: rgba(255, 255, 255, 0.1);
	}

	.benefit-icon {
		color: var(--color-accent);
		margin-bottom: 1.5rem;
	}

	.benefit-card h3 {
		font-size: 1.3rem;
		margin-bottom: 1rem;
	}

	.case-study {
		padding: 8rem 0;
		background: rgba(255, 255, 255, 0.02);
	}

	.case-study-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.case-study-text h2 {
		font-size: 2.5rem;
		margin-bottom: 1.5rem;
	}

	.case-intro {
		font-size: 1.2rem;
		line-height: 1.8;
		margin-bottom: 3rem;
	}

	.case-details {
		display: flex;
		justify-content: space-between;
		margin-bottom: 2rem;
	}

	.case-stat {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.stat-number {
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--color-accent);
	}

	.stat-label {
		font-size: 0.9rem;
		opacity: 0.8;
	}

	.case-description {
		margin-bottom: 2rem;
		line-height: 1.8;
	}

	.case-link {
		display: inline-block;
		color: var(--color-accent);
		text-decoration: none;
		font-weight: 500;
		transition: color 0.3s ease;
	}

	.case-link:hover {
		color: var(--color-white);
	}

	.case-study-image img {
		width: 100%;
		border-radius: 12px;
		box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
	}

	.faq {
		padding: 8rem 0;
	}

	.faq h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.faq-list {
		max-width: 800px;
		margin: 0 auto;
	}

	.faq-item {
		margin-bottom: 1.5rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.faq-item summary {
		padding: 1.5rem 0;
		font-size: 1.2rem;
		font-weight: 500;
		cursor: pointer;
		position: relative;
		list-style: none;
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-item summary::after {
		content: '+';
		position: absolute;
		right: 0;
		font-size: 1.5rem;
		transition: transform 0.3s ease;
	}

	.faq-item[open] summary::after {
		transform: rotate(45deg);
	}

	.faq-answer {
		padding: 0 0 1.5rem;
	}

	.cta-section {
		padding: 6rem 0;
		background: linear-gradient(rgba(72, 71, 68, 0.9), rgba(72, 71, 68, 0.9)), url('/approcheSeo.jpg') center/cover no-repeat;
		text-align: center;
	}

	.cta-section h2 {
		font-size: 2.5rem;
		margin-bottom: 1.5rem;
	}

	.cta-section p {
		font-size: 1.2rem;
		max-width: 800px;
		margin: 0 auto 2.5rem;
		opacity: 0.9;
	}

	.cta-buttons {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.primary-button, .secondary-button {
		padding: 1rem 2rem;
		border-radius: 50px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
	}

	.primary-button {
		background: var(--color-accent);
		color: var(--color-background);
	}

	.secondary-button {
		background: transparent;
		color: var(--color-white);
		border: 2px solid var(--color-accent);
	}

	.primary-button:hover, .secondary-button:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}

	@media (max-width: 992px) {
		.approach-content, .case-study-content {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.approach-image, .case-study-image {
			order: -1;
		}

		.case-details {
			flex-wrap: wrap;
			gap: 2rem;
		}

		.case-stat {
			flex: 1 0 30%;
		}
	}

	@media (max-width: 768px) {
		.hero {
			height: 70vh;
		}

		.hero h1 {
			font-size: 2.5rem;
		}

		.hero p {
			font-size: 1.2rem;
		}

		.services-grid, .benefits-grid {
			grid-template-columns: 1fr;
		}

		.cta-buttons {
			flex-direction: column;
			align-items: center;
		}
	}
</style>

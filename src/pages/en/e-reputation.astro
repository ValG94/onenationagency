---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Section from '../../components/Section.astro';

const metaDescription = "Protect and strengthen your online reputation with our e-reputation management services. Monitoring, crisis management and proactive strategies to reinforce your digital image.";
import { Image } from 'astro:assets';
import imgEReputation from '../../assets/e-reputation.jpg';
---


<Layout
	title="E-reputation Management and Brand Image | One Nation"
	description={metaDescription}
	lang="en"
	canonical="/en/e-reputation"
	ogImage="/images/e-reputation-banner.jpg"
>
	<Header lang="en" />
	<main id="main-content">
		<section class="hero">
			<div class="hero-content">
				<h1>E-reputation Management</h1>
				<p>Protect and strengthen your online image to build a solid, lasting digital reputation</p>
				<a href="/en/contact" class="cta-button">Discuss your project</a>
			</div>
		</section>

		<Section id="reputation-services" title="Our E-reputation Services">
			<div class="services-grid">
				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="11" cy="11" r="8"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
					</div>
					<h3>E-reputation audit</h3>
					<p>A complete analysis of your online presence, identifying the strengths, weaknesses and opportunities to improve your digital image.</p>
				</div>

				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
							<path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
							<line x1="9" y1="9" x2="9.01" y2="9"></line>
							<line x1="15" y1="9" x2="15.01" y2="9"></line>
						</svg>
					</div>
					<h3>Monitoring and watch</h3>
					<p>Continuous monitoring of your online reputation with real-time alerts and regular reports on mentions of your brand.</p>
				</div>

				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"></polygon>
							<line x1="12" y1="8" x2="12" y2="12"></line>
							<line x1="12" y1="16" x2="12.01" y2="16"></line>
						</svg>
					</div>
					<h3>Crisis management</h3>
					<p>Preparing and implementing contingency plans to handle crisis situations effectively and protect your reputation.</p>
				</div>

				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
							<polyline points="14 2 14 8 20 8"></polyline>
							<line x1="16" y1="13" x2="8" y2="13"></line>
							<line x1="16" y1="17" x2="8" y2="17"></line>
							<polyline points="10 9 9 9 8 9"></polyline>
						</svg>
					</div>
					<h3>Positive content creation</h3>
					<p>Developing and distributing quality content to reinforce your image and improve your online visibility.</p>
				</div>

				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
						</svg>
					</div>
					<h3>Review and comment management</h3>
					<p>Tracking and responding to customer reviews on rating platforms and social media to maintain a positive image.</p>
				</div>

				<div class="service-card">
					<div class="service-icon">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
							<circle cx="9" cy="7" r="4"></circle>
							<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
							<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
						</svg>
					</div>
					<h3>Training and awareness</h3>
					<p>Training your teams in online communication best practice and in handling sensitive situations.</p>
				</div>
			</div>
		</Section>

		<section class="process">
			<div class="container">
				<h2>Our approach to e-reputation</h2>
				<div class="process-steps">
					<div class="process-step">
						<div class="step-number">01</div>
						<div class="step-content">
							<h3>Audit & analysis</h3>
							<p>We begin with an in-depth analysis of your current online presence, your perceived image and the conversations surrounding your brand.</p>
						</div>
					</div>

					<div class="process-step">
						<div class="step-number">02</div>
						<div class="step-content">
							<h3>Strategy & planning</h3>
							<p>We develop a tailored strategy to build on your strengths, correct weaknesses and seize opportunities for improvement.</p>
						</div>
					</div>

					<div class="process-step">
						<div class="step-number">03</div>
						<div class="step-content">
							<h3>Setting up monitoring</h3>
							<p>We deploy monitoring tools to track mentions of your brand continuously and detect weak signals quickly.</p>
						</div>
					</div>

					<div class="process-step">
						<div class="step-number">04</div>
						<div class="step-content">
							<h3>Corrective and preventive action</h3>
							<p>We implement measures to resolve existing issues and prevent potential risks to your reputation.</p>
						</div>
					</div>

					<div class="process-step">
						<div class="step-number">05</div>
						<div class="step-content">
							<h3>Positive reinforcement</h3>
							<p>We develop and distribute positive content to strengthen your image and improve your online visibility.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="benefits">
			<div class="container">
				<h2>Why manage your e-reputation?</h2>
				<div class="benefits-grid">
					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
								<polyline points="22 4 12 14.01 9 11.01"></polyline>
							</svg>
						</div>
						<h3>Trust & credibility</h3>
						<p>A strong online reputation builds the confidence of customers, partners and stakeholders in your organisation.</p>
					</div>

					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<circle cx="12" cy="12" r="10"></circle>
								<polyline points="12 6 12 12 16 14"></polyline>
							</svg>
						</div>
						<h3>Crisis prevention</h3>
						<p>Active monitoring makes it possible to identify and resolve issues before they escalate into major crises.</p>
					</div>

					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<line x1="12" y1="1" x2="12" y2="23"></line>
								<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
							</svg>
						</div>
						<h3>Competitive advantage</h3>
						<p>A positive reputation sets you apart from the competition and can be the deciding factor in a client's choice.</p>
					</div>

					<div class="benefit-card">
						<div class="benefit-icon">
							<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
								<circle cx="9" cy="7" r="4"></circle>
								<path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
								<path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
							</svg>
						</div>
						<h3>Attracting talent</h3>
						<p>A strong e-reputation makes it easier to recruit and retain the best talent for your organisation.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="case-study">
			<div class="container">
				<div class="case-study-content">
					<div class="case-study-text">
						<h2>Crisis management & image recovery</h2>
						<p class="case-intro">See how we helped a company transform its online reputation in the wake of a media crisis.</p>

						<div class="case-details">
							<div class="case-stat">
								<span class="stat-number">+85%</span>
								<span class="stat-label">Positive sentiment</span>
							</div>

							<div class="case-stat">
								<span class="stat-number">-70%</span>
								<span class="stat-label">Negative mentions</span>
							</div>

							<div class="case-stat">
								<span class="stat-number">+40%</span>
								<span class="stat-label">Customer trust</span>
							</div>
						</div>

						<p class="case-description">Our client, a B2B services company, faced a reputation crisis following viral criticism on social media. We implemented a comprehensive strategy combining transparent crisis communication, proactive engagement with dissatisfied customers, and a positive content campaign highlighting the improvements made. Within six months, we had entirely transformed how the brand was perceived online.</p>
					</div>

					<div class="case-study-image">
						<Image src={imgEReputation} alt="Reputation management" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 768px) 100vw, 50vw" decoding="async" />
					</div>
				</div>
			</div>
		</section>

		<section class="faq">
			<div class="container">
				<h2>Frequently asked questions about e-reputation</h2>
				<div class="faq-list">
					<details class="faq-item">
						<summary>How do I know whether my e-reputation is at risk?</summary>
						<div class="faq-answer">
							<p>Several signals can point to an e-reputation problem: a sudden rise in negative mentions, unfavourable customer reviews, falling engagement on your content, or a drop in traffic to your website. A regular audit of your online presence is essential to detect these signals early. We offer monitoring tools that track your reputation continuously and alert you as soon as a potential problem is detected.</p>
						</div>
					</details>

					<details class="faq-item">
						<summary>Is it possible to remove negative content from the internet?</summary>
						<div class="faq-answer">
							<p>Removing negative content depends on several factors. If the content is defamatory, unlawful or breaches the platform's terms of use, it may be possible to have it taken down. In many cases, however, it is more effective to take a proactive approach by creating positive content that dilutes the impact of negative mentions in search results. Our approach combines removal requests, where justified, with a positive content strategy designed to improve your overall image.</p>
						</div>
					</details>

					<details class="faq-item">
						<summary>How long does it take to improve an e-reputation?</summary>
						<div class="faq-answer">
							<p>The time required to improve an e-reputation depends on how serious the initial situation is and on the scale of the measures put in place. For minor issues, significant results can be seen within three to six months. For more complex situations or major crises, six to twelve months of work may be necessary. It is important to understand that e-reputation management is a continuous process that requires long-term commitment in order to maintain and strengthen a positive image.</p>
						</div>
					</details>

					<details class="faq-item">
						<summary>How do you measure the effectiveness of an e-reputation strategy?</summary>
						<div class="faq-answer">
							<p>We use a number of indicators to measure the effectiveness of an e-reputation strategy: sentiment analysis (the ratio of positive to negative mentions), the volume and reach of mentions of your brand, how your content ranks in search results, changes in customer reviews, and the impact on your commercial KPIs (web traffic, conversion rate, and so on). We provide regular reports covering these metrics so you can track progress and adjust the strategy where necessary.</p>
						</div>
					</details>
				</div>
			</div>
		</section>

		<section class="cta-section">
			<div class="container">
				<h2>Protect and strengthen your online reputation</h2>
				<p>Contact us today for a free audit of your e-reputation and find out how we can help you build a positive, lasting image.</p>
				<div class="cta-buttons">
					<a href="/en/contact" class="primary-button">Request a free audit</a>
					<a href="/en/services" class="secondary-button">Explore our services</a>
				</div>
			</div>
		</section>
	</main>
	<Footer lang="en" />
</Layout>

<style>
	.hero {
		height: 80vh;
		min-height: 600px;
		background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('/e-reputation.jpg') center/cover no-repeat;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		margin-top: 72px;
	}

	.hero-content {
		max-width: 800px;
		padding: 0 2rem;
	}

	.hero h1 {
		font-size: 3.5rem;
		margin-bottom: 1.5rem;
		line-height: 1.2;
	}

	.hero p {
		font-size: 1.5rem;
		margin-bottom: 2rem;
		opacity: 0.9;
	}

	.cta-button {
		display: inline-block;
		background: var(--color-accent);
		color: var(--color-background);
		padding: 1rem 2rem;
		border-radius: 50px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
	}

	.cta-button:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.service-card {
		background: rgba(255, 255, 255, 0.05);
		padding: 2.5rem 2rem;
		border-radius: 12px;
		transition: transform 0.3s ease;
		text-align: center;
		height: 100%;
	}

	.service-card:hover {
		transform: translateY(-10px);
		background: rgba(255, 255, 255, 0.1);
	}

	.service-icon {
		color: var(--color-accent);
		margin-bottom: 1.5rem;
	}

	.service-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}

	.process {
		padding: 8rem 0;
		background: rgba(255, 255, 255, 0.02);
	}

	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.process h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.process-steps {
		max-width: 800px;
		margin: 0 auto;
	}

	.process-step {
		display: flex;
		gap: 2rem;
		margin-bottom: 3rem;
		position: relative;
	}

	.process-step:not(:last-child)::after {
		content: '';
		position: absolute;
		top: 3rem;
		left: 1.5rem;
		width: 2px;
		height: calc(100% + 3rem);
		background: rgba(255, 255, 255, 0.1);
		z-index: -1;
	}

	.step-number {
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--color-accent);
		flex-shrink: 0;
		width: 3rem;
		text-align: center;
	}

	.step-content h3 {
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.benefits {
		padding: 8rem 0;
	}

	.benefits h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.benefits-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 3rem;
	}

	.benefit-card {
		text-align: center;
		padding: 2rem;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 12px;
		transition: transform 0.3s ease;
	}

	.benefit-card:hover {
		transform: translateY(-10px);
		background: rgba(255, 255, 255, 0.1);
	}

	.benefit-icon {
		color: var(--color-accent);
		margin-bottom: 1.5rem;
	}

	.benefit-card h3 {
		font-size: 1.3rem;
		margin-bottom: 1rem;
	}

	.case-study {
		padding: 8rem 0;
		background: rgba(255, 255, 255, 0.02);
	}

	.case-study-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.case-study-text h2 {
		font-size: 2.5rem;
		margin-bottom: 1.5rem;
	}

	.case-intro {
		font-size: 1.2rem;
		line-height: 1.8;
		margin-bottom: 3rem;
	}

	.case-details {
		display: flex;
		justify-content: space-between;
		margin-bottom: 2rem;
	}

	.case-stat {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.stat-number {
		font-size: 2.5rem;
		font-weight: 700;
		color: var(--color-accent);
	}

	.stat-label {
		font-size: 0.9rem;
		opacity: 0.8;
	}

	.case-description {
		margin-bottom: 2rem;
		line-height: 1.8;
	}

	.case-study-image img {
		width: 100%;
		border-radius: 12px;
		box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
	}

	.faq {
		padding: 8rem 0;
	}

	.faq h2 {
		font-size: 2.5rem;
		text-align: center;
		margin-bottom: 4rem;
	}

	.faq-list {
		max-width: 800px;
		margin: 0 auto;
	}

	.faq-item {
		margin-bottom: 1.5rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}

	.faq-item summary {
		padding: 1.5rem 0;
		font-size: 1.2rem;
		font-weight: 500;
		cursor: pointer;
		position: relative;
		list-style: none;
	}

	.faq-item summary::-webkit-details-marker {
		display: none;
	}

	.faq-item summary::after {
		content: '+';
		position: absolute;
		right: 0;
		font-size: 1.5rem;
		transition: transform 0.3s ease;
	}

	.faq-item[open] summary::after {
		transform: rotate(45deg);
	}

	.faq-answer {
		padding: 0 0 1.5rem;
	}

	.cta-section {
		padding: 6rem 0;
		text-align: center;
		background: linear-gradient(rgba(72, 71, 68, 0.8), rgba(72, 71, 68, 0.9)), url('/porteCartes.jpg') center/cover no-repeat;
	}

	.cta-section h2 {
		font-size: 2.5rem;
		margin-bottom: 1.5rem;
	}

	.cta-section p {
		font-size: 1.2rem;
		max-width: 800px;
		margin: 0 auto 2.5rem;
		opacity: 0.9;
	}

	.cta-buttons {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.primary-button, .secondary-button {
		padding: 1rem 2rem;
		border-radius: 50px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.3s ease;
	}

	.primary-button {
		background: var(--color-accent);
		color: var(--color-background);
	}

	.secondary-button {
		background: transparent;
		color: var(--color-white);
		border: 2px solid var(--color-accent);
	}

	.primary-button:hover, .secondary-button:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}

	@media (max-width: 992px) {
		.case-study-content {
			grid-template-columns: 1fr;
			gap: 3rem;
		}

		.case-study-image {
			order: -1;
		}

		.process-step {
			flex-direction: column;
			gap: 1rem;
		}

		.process-step:not(:last-child)::after {
			display: none;
		}
	}

	@media (max-width: 768px) {
		.hero {
			height: 70vh;
		}

		.hero h1 {
			font-size: 2.5rem;
		}

		.hero p {
			font-size: 1.2rem;
		}

		.services-grid {
			grid-template-columns: 1fr;
		}

		.cta-buttons {
			flex-direction: column;
			align-items: center;
		}
	}
</style>

---
interface Props {
  lang?: string;
}
const { lang = 'fr' } = Astro.props;

const navFR = [
  { label: 'L\'Agence', href: '/vision' },
  { label: 'Expertises', href: '/services' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Intelligence IA', href: '/intelligence-artificielle' },
  { label: 'Contact', href: '/contact' },
];

const navEN = [
  { label: 'Agency', href: '/en/vision' },
  { label: 'Expertise', href: '/en/services' },
  { label: 'Portfolio', href: '/en/portfolio' },
  { label: 'AI Intelligence', href: '/en/artificial-intelligence' },
  { label: 'Contact', href: '/en/contact' },
];

const nav = lang === 'en' ? navEN : navFR;
const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="header-inner container">
    <!-- Logo -->
    <a href={lang === 'en' ? '/en' : '/'} class="logo" aria-label="One Nation Agency — Accueil">
      <img src="/logoOnenation.png" alt="One Nation Agency" width="140" height="40" />
    </a>

    <!-- Navigation desktop -->
    <nav class="nav-desktop" aria-label="Navigation principale">
      <ul>
        {nav.map(item => (
          <li>
            <a
              href={item.href}
              class={currentPath === item.href || currentPath.startsWith(item.href + '/') ? 'active' : ''}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Actions droite -->
    <div class="header-actions">
      <!-- Sélecteur de langue -->
      <div class="lang-switcher" aria-label="Changer de langue">
        <a href={lang === 'en' ? currentPath.replace('/en', '') || '/' : '/en'} class="lang-btn">
          {lang === 'en' ? 'FR' : 'EN'}
        </a>
      </div>

      <!-- CTA -->
      <a href={lang === 'en' ? '/en/contact' : '/contact'} class="header-cta btn-gold">
        {lang === 'en' ? 'Get in touch' : 'Nous contacter'}
      </a>

      <!-- Burger mobile -->
      <button class="burger" id="burger-btn" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Menu mobile -->
  <div class="mobile-menu" id="mobile-menu" role="dialog" aria-label="Menu mobile">
    <nav aria-label="Navigation mobile">
      <ul>
        {nav.map(item => (
          <li>
            <a href={item.href} class={currentPath === item.href ? 'active' : ''}>
              {item.label}
            </a>
          </li>
        ))}
        <li class="mobile-lang">
          <a href={lang === 'en' ? currentPath.replace('/en', '') || '/' : '/en'}>
            {lang === 'en' ? '🇫🇷 Français' : '🇬🇧 English'}
          </a>
        </li>
        <li>
          <a href={lang === 'en' ? '/en/contact' : '/contact'} class="btn-gold mobile-cta">
            {lang === 'en' ? 'Get in touch' : 'Nous contacter'}
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  /* ─── Header principal ─────────────────────────────────────── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    /* z-index élevé mais sans transform ni will-change qui créent un nouveau stacking context */
    z-index: 10000;
    padding: 0;
    transition: background 0.4s ease, backdrop-filter 0.4s ease, box-shadow 0.4s ease;
    /* IMPORTANT : pas de transform ici — un transform sur le parent
       réinitialise le stacking context et casse le fixed des enfants */
  }

  .site-header.scrolled {
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(201,168,76,0.12);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    gap: 2rem;
  }

  /* ─── Logo ─────────────────────────────────────────────────── */
  .logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .logo img {
    height: 36px;
    width: auto;
    filter: brightness(1);
    transition: opacity 0.2s ease;
  }
  .logo:hover img { opacity: 0.85; }

  /* ─── Nav desktop ───────────────────────────────────────────── */
  .nav-desktop ul {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .nav-desktop a {
    display: block;
    padding: 0.5rem 0.9rem;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--grey-light);
    border-radius: 3px;
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-desktop a::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0.9rem;
    right: 0.9rem;
    height: 1px;
    background: var(--gold);
    transform: scaleX(0);
    transition: transform 0.25s ease;
    transform-origin: left;
  }

  .nav-desktop a:hover,
  .nav-desktop a.active {
    color: var(--white);
  }

  .nav-desktop a:hover::after,
  .nav-desktop a.active::after {
    transform: scaleX(1);
  }

  /* ─── Actions droite ────────────────────────────────────────── */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  /* Sélecteur langue */
  .lang-switcher { display: flex; }
  .lang-btn {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--grey);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 0.35rem 0.7rem;
    border-radius: 3px;
    transition: all 0.2s ease;
    text-transform: uppercase;
  }
  .lang-btn:hover {
    color: var(--gold);
    border-color: var(--gold);
  }

  /* CTA header */
  .header-cta {
    font-size: 0.72rem;
    padding: 0.65rem 1.4rem;
  }

  /* ─── Burger ────────────────────────────────────────────────── */
  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    /* z-index relatif au header — toujours au-dessus du menu overlay */
    position: relative;
    z-index: 10002;
  }
  .burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .burger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ─── Menu mobile ───────────────────────────────────────────── */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    background: rgba(8,8,8,0.99);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    z-index: 10001;
    padding: 5rem 1.25rem 2rem;
    /* Scroll interne au menu uniquement */
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    /* Caché par défaut */
    visibility: hidden;
    opacity: 0;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1),
                opacity 0.35s ease,
                visibility 0s linear 0.35s;
  }
  .mobile-menu.open {
    visibility: visible;
    opacity: 1;
    transform: translateX(0);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1),
                opacity 0.35s ease,
                visibility 0s linear 0s;
  }
  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .mobile-menu a {
    display: block;
    padding: 1.1rem 0;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--grey-light);
    border-bottom: 1px solid var(--border-light);
    transition: color 0.2s ease;
    letter-spacing: 0.03em;
  }
  .mobile-menu a:hover,
  .mobile-menu a.active { color: var(--gold); }
  .mobile-menu .mobile-lang a {
    color: var(--grey);
    font-size: 0.95rem;
    font-weight: 500;
  }
  .mobile-menu .mobile-cta {
    margin-top: 2rem;
    width: 100%;
    justify-content: center;
    font-size: 0.82rem;
    padding: 1rem;
    border-bottom: none !important;
    color: var(--black) !important;
  }

  /* ─── Responsive ────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .nav-desktop { display: none; }
    .header-cta { display: none; }
    .burger { display: flex; }
    .lang-switcher { display: flex; }
  }

  @media (max-width: 480px) {
    .header-inner { height: 68px; }
    .logo img { height: 30px; }
    .mobile-menu { padding-top: 4.5rem; }
  }
</style>

<script>
  const header = document.getElementById('site-header') as HTMLElement | null;
  const burgerBtn = document.getElementById('burger-btn') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;

  // ── Effet scroll sur le header ──────────────────────────────
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }, { passive: true });

  // ── Helpers open / close ────────────────────────────────────
  function openMenu() {
    mobileMenu?.classList.add('open');
    burgerBtn?.classList.add('open');
    burgerBtn?.setAttribute('aria-expanded', 'true');
    // NE PAS bloquer document.body.overflow — le menu a son propre scroll interne
    // Bloquer uniquement le scroll de la page derrière le menu via pointer-events
  }

  function closeMenu() {
    mobileMenu?.classList.remove('open');
    burgerBtn?.classList.remove('open');
    burgerBtn?.setAttribute('aria-expanded', 'false');
    // S'assurer que le scroll de la page est toujours libéré
    document.body.style.overflow = '';
    document.body.style.position = '';
    document.documentElement.style.overflow = '';
  }

  // ── Toggle burger ───────────────────────────────────────────
  burgerBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('open');
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  // ── Fermer sur clic de lien ─────────────────────────────────
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      closeMenu();
    });
  });

  // ── Fermer sur Escape ───────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('open')) {
      closeMenu();
    }
  });

  // ── Sécurité : nettoyer overflow au chargement de la page ───
  // (au cas où une navigation précédente aurait laissé overflow:hidden)
  window.addEventListener('load', () => {
    document.body.style.overflow = '';
    document.body.style.position = '';
    document.documentElement.style.overflow = '';
  });

  // ── Sécurité : nettoyer overflow sur popstate (navigation) ──
  window.addEventListener('popstate', () => {
    closeMenu();
  });
</script>

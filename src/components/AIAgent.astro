          keywords: ["goodbye", "bye", "bye bye", "see you", "see you later", "farewell", "take care", "ciao", "have a good day", "have a nice day", "good day", "all the best", "until next time", "later"],
          reply: "Goodbye and see you soon! 👋<br/><br/>Don't hesitate to come back if you have any questions. The <strong>One Nation Agency</strong> team remains available via our <a href='/en/contact'>contact form</a> or on <a href='https://wa.me/33625523859' target='_blank'>WhatsApp</a>."
        },
        default: "I'm not sure I understand your request. Can you clarify? Our areas of expertise are: <strong>strategic communication</strong>, <strong>AI agents</strong> and <strong>premium web creation</strong>. <br/><br/>You can also contact us directly: <a href='/contact'>form</a> or <a href='https://wa.me/33625523859' target='_blank'>WhatsApp</a>."
      },
      inputPlaceholder: "Ask your question...",
      statusOnline: "Online",
      langToggle: "FR"
    }
  };

  let currentLang = 'fr';
  let isOpen = false;
  let isTyping = false;
  let conversationStarted = false;

  // Suivi de la conversation pour la notification
  let conversationLog: { role: string; text: string }[] = [];
  let contactRequested = false; // true si l'utilisateur a cliqué sur contact/WhatsApp
  let notificationSent = false;
  let notificationTimer: ReturnType<typeof setTimeout> | null = null;

  const trigger = document.getElementById('ai-agent-trigger');
  const window_ = document.getElementById('ai-agent-window');
  const messagesEl = document.getElementById('ai-messages');
  const suggestionsEl = document.getElementById('ai-suggestions');
  const inputEl = document.getElementById('ai-input') as HTMLInputElement;
  const sendBtn = document.getElementById('ai-send');
  const closeBtn = document.getElementById('ai-close-btn');
  const langToggle = document.getElementById('ai-lang-toggle');
  const iconClosed = document.querySelector('.ai-trigger-icon--closed') as HTMLElement;
  const iconOpen = document.querySelector('.ai-trigger-icon--open') as HTMLElement;
  const statusEl = document.querySelector('.ai-agent-status') as HTMLElement;

  // ── Notification silencieuse à l'équipe One Nation ──────────
  // Envoyée quand un visiteur a échangé avec l'agent mais n'a pas
  // formulé de demande de contact (pas de clic sur formulaire/WhatsApp).
  // Déclenché 90s après la dernière interaction, ou à la fermeture.
  async function sendVisitorNotification() {
    if (notificationSent || conversationLog.length === 0 || contactRequested) return;
    notificationSent = true;

    const summary = conversationLog
      .map(m => `[${m.role === 'user' ? 'Visiteur' : 'Agent'}] ${m.text}`)
      .join('\n');

    try {
      await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: 'Agent IA — Visiteur anonyme',
          email: 'noreply@onenationagency.com',
          subject: '🤖 Visiteur sans demande formulée — conversation agent IA',
          message: `Un visiteur a échangé avec l'agent IA sur le site sans formuler de demande de contact.\n\nPage visitée : ${window.location.href}\nDate : ${new Date().toLocaleString('fr-FR')}\n\n--- Conversation ---\n${summary}`,
          rgpd: true,
          _type: 'agent_notification' // flag interne pour ne pas envoyer de confirmation au visiteur
        })
      });
    } catch (_) {
      // Silencieux — ne pas perturber l'expérience utilisateur
    }
  }

  function resetNotificationTimer() {
    if (notificationTimer) clearTimeout(notificationTimer);
    // Si pas de demande formulée après 90s d'inactivité → notifier
    notificationTimer = setTimeout(sendVisitorNotification, 90_000);
  }

  // ── Helpers messages ─────────────────────────────────────────
  function addMessage(text: string, role: 'bot' | 'user') {
    const msg = document.createElement('div');
    msg.className = `ai-msg ai-msg--${role}`;
    const bubble = document.createElement('div');
    bubble.className = 'ai-msg-bubble';
    bubble.innerHTML = text;
    msg.appendChild(bubble);
    messagesEl!.appendChild(msg);
    messagesEl!.scrollTop = messagesEl!.scrollHeight;

    // Enregistrer dans le log (texte brut, sans HTML)
    const plainText = text.replace(/<[^>]+>/g, '').trim();
    if (plainText) conversationLog.push({ role, text: plainText });

    // Détecter si l'utilisateur a cliqué sur un lien contact
    bubble.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        const href = a.getAttribute('href') || '';
        if (href.includes('contact') || href.includes('wa.me') || href.includes('mailto')) {
          contactRequested = true;
          if (notificationTimer) clearTimeout(notificationTimer);
        }
      });
    });
  }

  function showTyping(): Promise<void> {
    return new Promise(resolve => {
      const typingEl = document.createElement('div');
      typingEl.className = 'ai-msg ai-msg--bot';
      typingEl.id = 'ai-typing-indicator';
      typingEl.innerHTML = '<div class="ai-typing-bubble"><span></span><span></span><span></span></div>';
      messagesEl!.appendChild(typingEl);
      messagesEl!.scrollTop = messagesEl!.scrollHeight;
      setTimeout(() => {
        typingEl.remove();
        resolve();
      }, 1200 + Math.random() * 600);
    });
  }

  type Suggestion = { label: string; url?: string; text?: string };

  function setSuggestions(suggestions: (string | Suggestion)[]) {
    suggestionsEl!.innerHTML = '';
    suggestions.forEach(s => {
      const item: Suggestion = typeof s === 'string' ? { label: s, text: s } : s;

      if (item.url) {
        // Lien direct vers une page du site
        const a = document.createElement('a');
        a.className = 'ai-suggestion-btn';
        a.textContent = item.label;
        a.href = item.url;
        if (item.url.startsWith('http')) a.target = '_blank';
        a.addEventListener('click', (e) => {
          e.stopPropagation();
          contactRequested = true;
          if (notificationTimer) clearTimeout(notificationTimer);
        });
        suggestionsEl!.appendChild(a);
      } else {
        // Bouton qui déclenche une réponse de l'agent
        const btn = document.createElement('button');
        btn.className = 'ai-suggestion-btn';
        btn.textContent = item.label;
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          handleUserInput(item.text || item.label);
        });
        suggestionsEl!.appendChild(btn);
      }
    });
  }

  function detectIntent(text: string): string {
    const lower = text.toLowerCase();
    const script = SCRIPTS[currentLang as keyof typeof SCRIPTS];
    for (const [key, val] of Object.entries(script.responses)) {
      if (key === 'default') continue;
      const { keywords } = val as { keywords: string[]; reply: string };
      if (keywords.some(kw => lower.includes(kw))) return key;
    }
    return 'default';
  }

  async function handleUserInput(text: string) {
    if (!text.trim() || isTyping) return;
    isTyping = true;
    sendBtn!.setAttribute('disabled', 'true');
    inputEl.value = '';
    suggestionsEl!.innerHTML = '';

    addMessage(text, 'user');
    resetNotificationTimer();

    await showTyping();

    const script = SCRIPTS[currentLang as keyof typeof SCRIPTS];
    const intent = detectIntent(text);
    const response = script.responses[intent as keyof typeof script.responses];
    const reply = typeof response === 'string' ? response : (response as { reply: string }).reply;

    addMessage(reply, 'bot');
    resetNotificationTimer();

    // Suggestions contextuelles après réponse — objets {label, url?, text?}
    // url  → lien direct vers la page du site
    // text → déclenche une nouvelle réponse de l'agent
    type Suggestion = { label: string; url?: string; text?: string };
    const followUpSuggestions: Record<string, Record<string, Suggestion[]>> = {
      fr: {
        communication: [
          { label: "Voir nos réalisations", url: "/portfolio" },
          { label: "Nous contacter", url: "/contact" },
          { label: "Agent IA", text: "Agent IA" }
        ],
        ia: [
          { label: "Demander une démo", url: "/contact" },
          { label: "Page Intelligence IA", url: "/intelligence-artificielle" },
          { label: "Nous contacter", url: "/contact" }
        ],
        web: [
          { label: "Voir le portfolio", url: "/portfolio" },
          { label: "Nous contacter", url: "/contact" },
          { label: "Communication", text: "Communication stratégique" }
        ],
        contact: [
          { label: "Formulaire de contact", url: "/contact" },
          { label: "WhatsApp", url: "https://wa.me/33625523859" },
          { label: "Voir nos expertises", url: "/expertises" }
        ],
        portfolio: [
          { label: "Voir le portfolio", url: "/portfolio" },
          { label: "Nous contacter", url: "/contact" },
          { label: "Agent IA", text: "Agent IA" }
        ],
        demo: [
          { label: "Formulaire de contact", url: "/contact" },
          { label: "WhatsApp", url: "https://wa.me/33625523859" },
          { label: "Page Intelligence IA", url: "/intelligence-artificielle" }
        ],
        salutation: [
          { label: "Communication stratégique", text: "Communication stratégique" },
          { label: "Agent IA", text: "Agent IA" },
          { label: "Création web", text: "Création web" },
          { label: "Nous contacter", url: "/contact" }
        ],
        merci: [
          { label: "Voir le portfolio", url: "/portfolio" },
          { label: "Nous contacter", url: "/contact" },
          { label: "WhatsApp", url: "https://wa.me/33625523859" }
        ],
        aurevoir: [
          { label: "Nous contacter", url: "/contact" },
          { label: "Voir le portfolio", url: "/portfolio" }
        ],
        default: [
          { label: "Communication", text: "Communication stratégique" },
          { label: "Agent IA", text: "Agent IA" },
          { label: "Portfolio", url: "/portfolio" },
          { label: "Nous contacter", url: "/contact" }
        ]
      },
      en: {
        communication: [
          { label: "See our portfolio", url: "/portfolio" },
          { label: "Contact us", url: "/contact" },
          { label: "AI Agent", text: "AI Agent" }
        ],
        ia: [
          { label: "Request a demo", url: "/contact" },
          { label: "AI Intelligence page", url: "/intelligence-artificielle" },
          { label: "Contact us", url: "/contact" }
        ],
        web: [
          { label: "View portfolio", url: "/portfolio" },
          { label: "Contact us", url: "/contact" },
          { label: "Communication", text: "Strategic Communication" }
        ],
        contact: [
          { label: "Contact form", url: "/contact" },
          { label: "WhatsApp", url: "https://wa.me/33625523859" },
          { label: "Our expertise", url: "/expertises" }
        ],
        portfolio: [
          { label: "View portfolio", url: "/portfolio" },
          { label: "Contact us", url: "/contact" },
          { label: "AI Agent", text: "AI Agent" }
        ],
        demo: [
          { label: "Contact form", url: "/contact" },
          { label: "WhatsApp", url: "https://wa.me/33625523859" },
          { label: "AI Intelligence page", url: "/intelligence-artificielle" }
        ],
        salutation: [
          { label: "Strategic Communication", text: "Strategic Communication" },
          { label: "AI Agent", text: "AI Agent" },
          { label: "Web Creation", text: "Web Creation" },
          { label: "Contact us", url: "/en/contact" }
        ],
        merci: [
          { label: "View portfolio", url: "/portfolio" },
          { label: "Contact us", url: "/en/contact" },
          { label: "WhatsApp", url: "https://wa.me/33625523859" }
        ],
        aurevoir: [
          { label: "Contact us", url: "/en/contact" },
          { label: "View portfolio", url: "/portfolio" }
        ],
        default: [
          { label: "Communication", text: "Strategic Communication" },
          { label: "AI Agent", text: "AI Agent" },
          { label: "Portfolio", url: "/portfolio" },
          { label: "Contact us", url: "/contact" }
        ]
      }
    };

    const followUp = followUpSuggestions[currentLang][intent] || followUpSuggestions[currentLang]['default'];
    setSuggestions(followUp);

    isTyping = false;
    sendBtn!.removeAttribute('disabled');
  }

  function openAgent() {
    isOpen = true;
    window_!.hidden = false;
    trigger!.setAttribute('aria-expanded', 'true');
    iconClosed.style.display = 'none';
    iconOpen.style.display = 'flex';
    inputEl.focus();

    if (!conversationStarted) {
      conversationStarted = true;
      const script = SCRIPTS[currentLang as keyof typeof SCRIPTS];
      setTimeout(() => {
        addMessage(script.welcome, 'bot');
        setSuggestions(script.suggestions);
      }, 200);
    }
  }

  function closeAgent() {
    isOpen = false;
    window_!.hidden = true;
    trigger!.setAttribute('aria-expanded', 'false');
    iconClosed.style.display = 'flex';
    iconOpen.style.display = 'none';

    // Si conversation sans demande formulée → notifier immédiatement
    if (conversationLog.length > 0 && !contactRequested && !notificationSent) {
      sendVisitorNotification();
    }
  }

  function toggleLang() {
    currentLang = currentLang === 'fr' ? 'en' : 'fr';
    const script = SCRIPTS[currentLang as keyof typeof SCRIPTS];
    langToggle!.textContent = script.langToggle;
    inputEl.placeholder = script.inputPlaceholder;
    statusEl.querySelector('span:last-child')!.textContent = script.statusOnline;

    // Reset conversation in new language
    messagesEl!.innerHTML = '';
    suggestionsEl!.innerHTML = '';
    conversationStarted = false;
    conversationLog = [];
    contactRequested = false;
    notificationSent = false;
    if (isOpen) {
      setTimeout(() => {
        addMessage(script.welcome, 'bot');
        setSuggestions(script.suggestions);
        conversationStarted = true;
      }, 100);
    }
  }

  // ── EVENT LISTENERS ──────────────────────────────────────────

  // Bouton trigger : ouvre/ferme
  trigger!.addEventListener('click', (e) => {
    e.stopPropagation();
    isOpen ? closeAgent() : openAgent();
  });

  // Bouton fermer (×) dans le header
  closeBtn!.addEventListener('click', (e) => {
    e.stopPropagation();
    closeAgent();
  });

  // Toggle langue
  langToggle!.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleLang();
  });

  // Envoi message
  sendBtn!.addEventListener('click', (e) => {
    e.stopPropagation();
    if (inputEl.value.trim()) handleUserInput(inputEl.value.trim());
  });

  inputEl.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      if (inputEl.value.trim()) handleUserInput(inputEl.value.trim());
    }
  });

  // Fermer en cliquant EN DEHORS de la fenêtre
  // (stopPropagation sur les boutons internes évite les faux positifs)
  document.addEventListener('click', (e) => {
    const agent = document.getElementById('ai-agent');
    if (isOpen && agent && !agent.contains(e.target as Node)) {
      closeAgent();
    }
  });

  // Notifier à la fermeture de la page si conversation sans demande
  window.addEventListener('beforeunload', () => {
    if (conversationLog.length > 0 && !contactRequested && !notificationSent) {
      // sendBeacon pour garantir l'envoi même si la page se ferme
      const payload = JSON.stringify({
        name: 'Agent IA — Visiteur anonyme',
        email: 'noreply@onenationagency.com',
        subject: '🤖 Visiteur sans demande formulée — conversation agent IA',
        message: `Visiteur parti sans formuler de demande.\n\nPage : ${window.location.href}\nDate : ${new Date().toLocaleString('fr-FR')}\n\n--- Conversation ---\n${conversationLog.map(m => `[${m.role === 'user' ? 'Visiteur' : 'Agent'}] ${m.text}`).join('\n')}`,
        rgpd: true,
        _type: 'agent_notification'
      });
      navigator.sendBeacon('/api/contact', new Blob([payload], { type: 'application/json' }));
    }
  });
</script>

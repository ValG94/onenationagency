---
import AIAgent from '../components/AIAgent.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  lang?: string;
  ogImage?: string;
  canonical?: string;
  keywords?: string;
}

const {
  title,
  description = "One Nation Agency — Communication stratégique institutionnelle, agents IA sur mesure et création web premium pour la France et l'Afrique.",
  lang = "fr",
  ogImage = "/og-image-v2.jpg",
  canonical = Astro.url.pathname,
  keywords = "agence communication, agent IA, création web, communication institutionnelle, Afrique, France, intelligence artificielle, stratégie digitale"
} = Astro.props;

const fullOgImageUrl = ogImage.startsWith('http') ? ogImage : `https://www.onenationagency.com${ogImage}`;

const fullCanonicalUrl = `https://www.onenationagency.com${canonical}`;
const isHomePage = Astro.url.pathname === '/';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="author" content="One Nation Agency" />
  <meta name="geo.region" content="FR-75" />
  <meta name="geo.placename" content="Paris" />
  <link rel="canonical" href={fullCanonicalUrl} />
  {lang === 'fr' && <link rel="alternate" hreflang="fr" href={fullCanonicalUrl} />}
  {lang === 'fr' && <link rel="alternate" hreflang="en" href={`https://www.onenationagency.com/en${canonical === '/' ? '' : canonical}`} />}
  {lang === 'en' && <link rel="alternate" hreflang="en" href={fullCanonicalUrl} />}
  {lang === 'en' && <link rel="alternate" hreflang="fr" href={`https://www.onenationagency.com${canonical.replace('/en', '') || '/'}`} />}
  <link rel="alternate" hreflang="x-default" href="https://www.onenationagency.com/" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullOgImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={`${title} — One Nation Agency`} />
  <meta property="og:url" content={fullCanonicalUrl} />
  <meta property="og:site_name" content="One Nation Agency" />
  <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImageUrl} />
  <meta name="twitter:site" content="@onenationagency" />
  <meta name="twitter:creator" content="@onenationagency" />

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#C9A84C" />
  <meta name="msapplication-TileColor" content="#0A0A0A" />
  <meta name="msapplication-TileImage" content="/web-app-manifest-192x192.png" />

  <!-- Google Fonts Premium -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <title>{title}</title>

  <!-- Schema.org -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["ProfessionalService", "LocalBusiness"],
      "name": "One Nation Agency",
      "url": "https://www.onenationagency.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.onenationagency.com/logoOnenation.png",
        "width": 200,
        "height": 60
      },
      "image": "https://www.onenationagency.com/og-image-v2.jpg",
      "description": "One Nation Agency est une agence premium spécialisée en communication stratégique institutionnelle, création d'agents IA sur mesure et création web haut de gamme pour la France et l'Afrique.",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "3 rue de Suresnes",
        "addressLocality": "Paris",
        "postalCode": "75008",
        "addressCountry": "FR"
      },
      "telephone": "+33625523859",
      "email": "contact@onenationagency.com",
      "priceRange": "€€€",
      "areaServed": ["FR", "CM", "CI", "SN", "GA", "CD", "CF"],
      "serviceType": ["Communication stratégique", "Agent IA", "Création web", "Design graphique", "Référencement SEO"],
      "foundingDate": "2020",
      "knowsLanguage": ["fr", "en"],
      "sameAs": [
        "https://www.linkedin.com/company/one-nation-agency",
        "https://www.instagram.com/onenationagency"
      ]
    }
  </script>
</head>
<body>
  <a href="#main-content" class="skip-to-content">Aller au contenu principal</a>
  <slot />

  <AIAgent />
  <CookieBanner lang={lang} />

  {!isHomePage && (
    <a
      href="https://wa.me/33625523859"
      class="whatsapp-btn"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Nous contacter sur WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564.289.13.332.202c.045.072.045.419-.1.824zm-3.423-14.416c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12zm.029 18.88c-1.161 0-2.305-.292-3.318-.844l-3.677.964.984-3.595c-.607-1.052-.927-2.246-.926-3.468.001-3.825 3.113-6.937 6.937-6.937 1.856.001 3.598.723 4.907 2.034 1.31 1.311 2.031 3.054 2.03 4.908-.001 3.825-3.113 6.938-6.937 6.938z"/>
      </svg>
    </a>
  )}

  <style is:global>
    /* =============================================
       ONE NATION AGENCY — DESIGN SYSTEM NOIR / OR
    ============================================= */
    :root {
      --black:        #0A0A0A;
      --anthracite:   #111111;
      --dark:         #1A1A1A;
      --card-bg:      #161616;
      --white:        #FFFFFF;
      --off-white:    #F0EDE8;
      --gold:         #C9A84C;
      --gold-light:   #E2C27D;
      --gold-dark:    #9A7A30;
      --grey:         #888888;
      --grey-light:   #BBBBBB;
      --border:       rgba(201,168,76,0.18);
      --border-light: rgba(255,255,255,0.06);

      /* Alias compatibilité ancienne version */
      --color-background: #0A0A0A;
      --color-white:      #FFFFFF;
      --color-accent:     #C9A84C;

      --font-display: 'Montserrat', sans-serif;
      --font-body:    'Inter', 'Montserrat', sans-serif;

      --max-w:        1200px;
      --pad-x:        2rem;
      --pad-section:  7rem 0;

      --ease:         cubic-bezier(0.25, 0.46, 0.45, 0.94);
      --ease-out:     cubic-bezier(0.16, 1, 0.3, 1);
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      font-family: var(--font-body);
      background: var(--black);
      color: var(--white);
      scroll-behavior: smooth;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
    }

    main { flex: 1; }

    img { max-width: 100%; height: auto; display: block; }

    a { color: inherit; text-decoration: none; }

    a:focus-visible,
    button:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 3px;
      border-radius: 3px;
    }

    input:focus-visible,
    textarea:focus-visible,
    select:focus-visible {
      outline: 2px solid var(--gold);
      outline-offset: 0;
    }

    /* Typographie */
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-display);
      font-weight: 800;
      line-height: 1.08;
      letter-spacing: -0.02em;
      color: var(--white);
    }

    p {
      line-height: 1.75;
      color: var(--grey-light);
      font-size: 1rem;
    }

    /* Conteneur */
    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 var(--pad-x);
    }

    /* ---- Boutons ---- */
    .btn-gold {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--gold);
      color: var(--black);
      padding: 0.85rem 2.2rem;
      border-radius: 3px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      transition: background 0.25s var(--ease), transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
      text-decoration: none;
      white-space: nowrap;
    }
    .btn-gold:hover {
      background: var(--gold-light);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(201,168,76,0.25);
    }

    .btn-outline {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: transparent;
      color: var(--gold);
      padding: 0.82rem 2.2rem;
      border-radius: 3px;
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border: 1px solid var(--gold);
      cursor: pointer;
      transition: all 0.25s var(--ease);
      text-decoration: none;
      white-space: nowrap;
    }
    .btn-outline:hover {
      background: var(--gold);
      color: var(--black);
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(201,168,76,0.25);
    }

    /* ---- Labels & décorations ---- */
    .label {
      display: inline-block;
      font-family: var(--font-display);
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold);
    }

    .gold-bar {
      width: 36px;
      height: 2px;
      background: var(--gold);
      margin: 0.9rem 0 1.4rem;
    }

    /* ---- Animations ---- */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes shimmer {
      0%   { background-position: -200% center; }
      100% { background-position: 200% center; }
    }
    @keyframes pulseGold {
      0%, 100% { box-shadow: 0 0 0 0 rgba(201,168,76,0.5); }
      50%       { box-shadow: 0 0 0 10px rgba(201,168,76,0); }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50%       { transform: translateY(-6px); }
    }

    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.75s var(--ease-out), transform 0.75s var(--ease-out);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }

    /* ---- WhatsApp bouton ---- */
    .whatsapp-btn {
      position: fixed;
      bottom: 24px;
      right: 24px;
      background: #25D366;
      color: #fff;
      width: 52px;
      height: 52px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 4px 20px rgba(37,211,102,0.35);
      transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
      z-index: 800;
    }
    .whatsapp-btn:hover {
      transform: scale(1.1);
      box-shadow: 0 6px 28px rgba(37,211,102,0.5);
    }

    /* ---- Skip to content ---- */
    .skip-to-content {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }
    .skip-to-content:focus {
      position: fixed;
      top: 0;
      left: 0;
      width: auto;
      height: auto;
      padding: 10px 20px;
      background: var(--gold);
      color: var(--black);
      z-index: 9999;
      font-weight: 700;
    }

    /* ---- Scrollbar ---- */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: var(--anthracite); }
    ::-webkit-scrollbar-thumb { background: var(--gold-dark); border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--gold); }

    /* ---- Selection ---- */
    ::selection { background: var(--gold); color: var(--black); }

    /* ---- Responsive ---- */
    @media (max-width: 768px) {
      :root {
        --pad-x: 1.25rem;
        --pad-section: 4.5rem 0;
      }
      .whatsapp-btn { bottom: 16px; right: 16px; width: 46px; height: 46px; }
    }

    @media print {
      .whatsapp-btn { display: none !important; }
      body { background: white; color: black; }
    }
  </style>

  <!-- Intersection Observer global pour animations reveal -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    });
  </script>
</body>
</html>
